<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="LTools.UI.App"
             xmlns:local="using:LTools.UI"
             RequestedThemeVariant="Default">

    <Application.DataTemplates>
        <local:ViewLocator/>
    </Application.DataTemplates>

    <Application.Styles>
        <FluentTheme />

        <StyleInclude Source="/Styles/Typography.axaml" />
        <StyleInclude Source="/Styles/Spacing.axaml" />
        <StyleInclude Source="/Styles/Buttons.axaml" />
        <StyleInclude Source="/Styles/Cards.axaml" />
        <StyleInclude Source="/Styles/Inputs.axaml" />
        <StyleInclude Source="/Styles/Console.axaml" />

        <Style Selector="Window">
            <Setter Property="Background" Value="{DynamicResource PageBackground}" />
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}" />
        </Style>
        <Style Selector="UserControl">
            <Setter Property="Background" Value="{DynamicResource PageBackground}" />
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}" />
        </Style>
    </Application.Styles>
</Application>
