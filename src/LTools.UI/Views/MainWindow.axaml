<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:LTools.UI.ViewModels"
        xmlns:conv="using:LTools.UI.Converters"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1100" d:DesignHeight="700"
        x:Class="LTools.UI.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="LTools — Laravel Toolkit"
        Icon="/Assets/avalonia-logo.ico"
         Width="1100" Height="700"
         MinWidth="800" MinHeight="500"
         WindowState="Maximized">

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <Grid RowDefinitions="Auto,*,Auto">

        <!-- ════════════════════════════════════════
             ROW 0: CommandBar
             ════════════════════════════════════════ -->
        <Border Background="{DynamicResource AccentColor}" Padding="12,8">
            <Grid ColumnDefinitions="Auto,*,Auto">
                <Button Classes="Icon"
                        Command="{Binding SelectGlobalProjectCommand}"
                        ToolTip.Tip="Abrir projeto Laravel">
                    <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                        <TextBlock Text="📂" FontSize="16" />
                        <TextBlock Text="{Binding GlobalProjectName, TargetNullValue='Abrir Projeto'}"
                                   FontSize="14" FontWeight="SemiBold" Foreground="White"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </Button>

                <TextBlock Grid.Column="1" Text="{Binding GlobalProjectPath}"
                           FontSize="12" Foreground="#CCFFFFFF" VerticalAlignment="Center"
                           Margin="12,0,0,0"
                           IsVisible="{Binding HasGlobalProject}"
                           TextTrimming="CharacterEllipsis" />

                <TextBlock Grid.Column="2" Text="Laravel Toolkit" FontSize="18" FontWeight="Bold"
                           Foreground="White" VerticalAlignment="Center" />
            </Grid>
        </Border>

        <!-- ════════════════════════════════════════
             ROW 1: Sidebar + Content
             ════════════════════════════════════════ -->
        <Grid Grid.Row="1" ColumnDefinitions="220,*">

            <!-- Sidebar -->
            <Border Background="{DynamicResource SidebarBackground}">
                <DockPanel>
                    <ScrollViewer Padding="6">
                        <StackPanel Spacing="2">
                            <ItemsControl ItemsSource="{Binding Plugins}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="vm:PluginItemViewModel">
                                        <Border CornerRadius="6"
                                                Background="{Binding IsSelected, Converter={x:Static conv:BoolToBgConverter.Instance}}">
                                            <Button Command="{Binding $parent[Window].DataContext.SelectPluginCommand}"
                                                    CommandParameter="{Binding .}"
                                                    Background="Transparent"
                                                    BorderThickness="0"
                                                    HorizontalContentAlignment="Stretch"
                                                    Padding="8,6"
                                                    Cursor="Hand">
                                                <Grid ColumnDefinitions="Auto,*">
                                                    <TextBlock Text="{Binding Icon}" FontSize="16"
                                                               VerticalAlignment="Center" />
                                                    <TextBlock Grid.Column="1" Text="{Binding Name}"
                                                               Margin="10,0,0,0"
                                                               VerticalAlignment="Center"
                                                               FontSize="14"
                                                               Foreground="{DynamicResource TextPrimary}" />
                                                </Grid>
                                            </Button>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </ScrollViewer>
                </DockPanel>
            </Border>

            <!-- Content Panel -->
            <Border Grid.Column="1">
                <Grid RowDefinitions="Auto,*">
                    <!-- Page header -->
                    <Border Padding="16,8" Background="{DynamicResource OverlayLight}">
                        <TextBlock Text="{Binding CurrentPluginName}" FontSize="{DynamicResource FontSizeSectionTitle}"
                                   FontWeight="SemiBold" />
                    </Border>

                    <!-- Plugin content -->
                    <ContentControl Grid.Row="1" Content="{Binding CurrentView}" />
                </Grid>
            </Border>
        </Grid>

        <!-- ════════════════════════════════════════
             ROW 2: Status Bar
             ════════════════════════════════════════ -->
        <Border Grid.Row="2" Padding="10,4" Background="{DynamicResource OverlayMedium}"
                BorderBrush="{DynamicResource BorderColor}" BorderThickness="0,1,0,0">
            <Grid ColumnDefinitions="Auto,Auto,*,Auto">
                <TextBlock Text="{Binding AppVersion, StringFormat='v{0}'}" FontSize="11"
                           Opacity="0.4" VerticalAlignment="Center" />
                <Button Grid.Column="1" Command="{Binding ToggleThemeCommand}"
                        Classes="Small" ToolTip.Tip="Alternar tema"
                        Margin="8,0,0,0" Background="{DynamicResource CardBackground}">
                    <TextBlock Text="{Binding ThemeToggleIcon}" FontSize="12" />
                </Button>
                <TextBlock Grid.Column="2" Text="{Binding StatusMessage}"
                           FontSize="11" Foreground="#CCFFFFFF" VerticalAlignment="Center"
                           Margin="12,0,0,0" TextTrimming="CharacterEllipsis" />
                <Button Grid.Column="3" Command="{Binding OpenSiteCommand}"
                        Classes="Icon" ToolTip.Tip="lab.werneck.dev.br">
                    <TextBlock Text="Desenvolvido por Werneck Lab" FontSize="11" Opacity="0.5" />
                </Button>
            </Grid>
        </Border>
    </Grid>

</Window>
