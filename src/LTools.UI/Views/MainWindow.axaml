<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:LTools.UI.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1100" d:DesignHeight="700"
        x:Class="LTools.UI.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="LTools — Laravel Toolkit"
        Icon="/Assets/avalonia-logo.ico"
        Width="1100" Height="700"
        MinWidth="800" MinHeight="500">

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <Grid RowDefinitions="Auto,*,Auto">
        <Border Padding="12 8" Background="#100078D4">
            <Grid ColumnDefinitions="Auto,*,Auto">
                <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                    <Button Command="{Binding SelectGlobalProjectCommand}"
                            Background="#33FFFFFF" BorderThickness="0"
                            Padding="12 6" CornerRadius="4">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <TextBlock Text="📂" FontSize="14" VerticalAlignment="Center" />
                            <TextBlock Text="{Binding GlobalProjectName, TargetNullValue='Abrir Projeto'}"
                                       FontSize="13" FontWeight="SemiBold" Foreground="White" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                    <TextBlock Text="{Binding GlobalProjectPath}"
                               FontSize="13" Foreground="#CCFFFFFF" VerticalAlignment="Center"
                               IsVisible="{Binding HasGlobalProject}" />
                </StackPanel>
                <TextBlock Grid.Column="2" Text="LTools" FontSize="18" FontWeight="Bold" Foreground="White" VerticalAlignment="Center" />
            </Grid>
        </Border>

        <Grid Grid.Row="1" ColumnDefinitions="220,*">
            <Border Background="#100078D4">
                <ScrollViewer Padding="8">
                    <StackPanel Spacing="4">
                        <ItemsControl ItemsSource="{Binding Plugins}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:PluginItemViewModel">
                                    <Border Margin="0,2" CornerRadius="6">
                                        <Button Command="{Binding $parent[Window].DataContext.SelectPluginCommand}"
                                                CommandParameter="{Binding .}"
                                                Background="Transparent"
                                                BorderThickness="0"
                                                HorizontalContentAlignment="Stretch"
                                                Padding="8,6">
                                            <Grid ColumnDefinitions="Auto,*">
                                                <TextBlock Text="{Binding Icon}" FontSize="16" VerticalAlignment="Center" />
                                                <TextBlock Grid.Column="1" Text="{Binding Name}" Margin="10,0,0,0"
                                                           VerticalAlignment="Center" FontSize="14" />
                                            </Grid>
                                        </Button>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <Border Grid.Column="1">
                <Grid RowDefinitions="Auto,*">
                    <Border Padding="16 8" Background="#05000000">
                        <TextBlock Text="{Binding CurrentPluginName}" FontSize="16" FontWeight="SemiBold" />
                    </Border>

                    <ContentControl Grid.Row="1" Content="{Binding CurrentView}" />
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="2" Padding="10 4" Background="#0A000000" BorderBrush="#33000000" BorderThickness="0 1 0 0">
            <Grid ColumnDefinitions="Auto,*,Auto">
                <TextBlock Text="{Binding AppVersion, StringFormat='v{0}'}" FontSize="11" Opacity="0.4" VerticalAlignment="Center" />
                <Button Grid.Column="2" Command="{Binding OpenSiteCommand}"
                        Background="Transparent" BorderThickness="0"
                        Padding="4" Cursor="Hand">
                    <TextBlock Text="Desenvolvido por Werneck Lab" FontSize="11" Opacity="0.5" />
                </Button>
            </Grid>
        </Border>
    </Grid>

</Window>