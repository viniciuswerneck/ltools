<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Style Selector="TextBox.Console">
        <Setter Property="FontFamily" Value="Consolas" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Foreground" Value="{DynamicResource ConsoleForeground}" />
        <Setter Property="Background" Value="{DynamicResource ConsoleBackground}" />
        <Setter Property="BorderBrush" Value="{DynamicResource ConsoleBorder}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="IsReadOnly" Value="True" />
        <Setter Property="AcceptsReturn" Value="True" />
        <Setter Property="TextWrapping" Value="NoWrap" />
        <Setter Property="Padding" Value="8" />
        <Setter Property="IsHitTestVisible" Value="False" />
    </Style>

    <Style Selector="TextBox.Console /template/ Border#border">
        <Setter Property="Background" Value="{DynamicResource ConsoleBackground}" />
        <Setter Property="BorderBrush" Value="{DynamicResource ConsoleBorder}" />
    </Style>

    <Style Selector="Border.Badge">
        <Setter Property="CornerRadius" Value="3" />
        <Setter Property="Padding" Value="6,2" />
        <Setter Property="Background" Value="{DynamicResource AccentBg}" />
    </Style>
    <Style Selector="Border.Badge TextBlock">
        <Setter Property="FontSize" Value="11" />
        <Setter Property="Foreground" Value="{DynamicResource AccentLight}" />
    </Style>

</Styles>
