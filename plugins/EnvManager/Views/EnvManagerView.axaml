<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:LTools.EnvManager.ViewModels"
             x:DataType="vm:EnvManagerViewModel"
             x:Class="LTools.EnvManager.Views.EnvManagerView">

    <Grid RowDefinitions="Auto,*,Auto">
        <Border Padding="12 8" BorderBrush="{DynamicResource BorderColor}" BorderThickness="0 0 0 1">
            <Grid ColumnDefinitions="Auto,*,Auto">
                <ComboBox ItemsSource="{Binding EnvFiles}"
                          SelectedItem="{Binding SelectedEnvFile}"
                          MinWidth="160" Margin="0 0 8 0" />

                <TextBlock Grid.Column="1" Text="{Binding StatusMessage}"
                           VerticalAlignment="Center" FontSize="12" Opacity="0.7" />

                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="4">
                    <Button Command="{Binding SaveEnvCommand}" Classes="Primary">
                        💾 Salvar
                    </Button>
                    <Button Command="{Binding RestoreBackupCommand}" Classes="Secondary">
                        🔄 Restaurar
                    </Button>
                    <Button Command="{Binding CreateEnvFromExampleCommand}" Classes="Secondary">
                        ➕ .env
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1" Margin="8" CornerRadius="4" BorderBrush="{DynamicResource BorderLight}" BorderThickness="1">
            <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                <TextBox Text="{Binding EnvContent}"
                         Classes="Console"
                         AcceptsReturn="True"
                         BorderThickness="0"
                         Padding="12" />
            </ScrollViewer>
        </Border>

        <Border Grid.Row="2" Padding="12 6" BorderBrush="{DynamicResource BorderColor}" BorderThickness="0 1 0 0">
            <Grid ColumnDefinitions="Auto,*,Auto">
                <TextBlock Text="{Binding StatusMessage}" FontSize="12" Opacity="0.6" VerticalAlignment="Center" />
                <TextBlock Grid.Column="2" Text="{Binding HasUnsavedChanges, StringFormat='⚠ Alterações não salvas'}"
                           FontSize="12" Foreground="{DynamicResource WarningColor}" VerticalAlignment="Center"
                           IsVisible="{Binding HasUnsavedChanges}" />
            </Grid>
        </Border>
    </Grid>

</UserControl>
