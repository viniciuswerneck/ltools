<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:LTools.CacheExplorer.ViewModels"
             x:DataType="vm:CacheExplorerViewModel"
             x:Class="LTools.CacheExplorer.Views.CacheExplorerView">

    <Grid RowDefinitions="Auto,Auto,*">
        <Border Padding="12 8" BorderBrush="{DynamicResource BorderColor}" BorderThickness="0 0 0 1">
            <TextBlock Text="{Binding StatusMessage}" VerticalAlignment="Center" FontSize="12" Opacity="0.7" />
        </Border>

        <Border Grid.Row="1" Padding="8 6 8 0">
            <WrapPanel>
                <Button Command="{Binding ClearAllCommand}" Classes="Danger" Margin="0 0 10 8">
                    <StackPanel Orientation="Horizontal" Spacing="5">
                        <TextBlock Text="🔥" FontSize="13" />
                        <TextBlock Text="Limpar Tudo" />
                    </StackPanel>
                </Button>
                <Button Command="{Binding ClearApplicationCommand}" Classes="Primary" Margin="0 0 10 8">
                    <StackPanel Orientation="Horizontal" Spacing="5">
                        <TextBlock Text="🗑" FontSize="13" />
                        <TextBlock Text="Limpar Cache" />
                    </StackPanel>
                </Button>
                <Button Command="{Binding ClearConfigCommand}" Classes="Secondary" Margin="0 0 10 8">
                    <StackPanel Orientation="Horizontal" Spacing="5">
                        <TextBlock Text="⚙️" FontSize="13" />
                        <TextBlock Text="Config" />
                    </StackPanel>
                </Button>
                <Button Command="{Binding ClearRouteCommand}" Classes="Secondary" Margin="0 0 10 8">
                    <StackPanel Orientation="Horizontal" Spacing="5">
                        <TextBlock Text="🗺️" FontSize="13" />
                        <TextBlock Text="Rotas" />
                    </StackPanel>
                </Button>
                <Button Command="{Binding ClearViewCommand}" Classes="Secondary" Margin="0 0 10 8">
                    <StackPanel Orientation="Horizontal" Spacing="5">
                        <TextBlock Text="👁️" FontSize="13" />
                        <TextBlock Text="Views" />
                    </StackPanel>
                </Button>
                <Button Command="{Binding ClearEventCommand}" Classes="Secondary" Margin="0 0 10 8">
                    <StackPanel Orientation="Horizontal" Spacing="5">
                        <TextBlock Text="📅" FontSize="13" />
                        <TextBlock Text="Events" />
                    </StackPanel>
                </Button>
            </WrapPanel>
        </Border>

        <Grid Grid.Row="2" Margin="8" RowDefinitions="Auto,*">
            <Grid ColumnDefinitions="Auto,*,Auto">
                <TextBlock Text="Saída" FontSize="{DynamicResource FontSizeBody}" FontWeight="SemiBold" VerticalAlignment="Center" />
                <Button Grid.Column="2" Command="{Binding ClearOutputCommand}" Classes="Small">
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <TextBlock Text="🗑" />
                        <TextBlock Text="Limpar" />
                    </StackPanel>
                </Button>
            </Grid>
            <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto" Margin="0 6 0 0">
                <TextBox Text="{Binding OutputText}"
                         Classes="Console"
                         TextWrapping="Wrap" />
            </ScrollViewer>
        </Grid>
    </Grid>

</UserControl>
