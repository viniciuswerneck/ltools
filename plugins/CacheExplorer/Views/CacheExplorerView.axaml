<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:LTools.CacheExplorer.ViewModels"
             x:DataType="vm:CacheExplorerViewModel"
             x:Class="LTools.CacheExplorer.Views.CacheExplorerView">

    <Grid RowDefinitions="Auto,Auto,*">
        <Border Padding="12 8" BorderBrush="#33000000" BorderThickness="0 0 0 1">
            <TextBlock Text="{Binding StatusMessage}" VerticalAlignment="Center" FontSize="12" Opacity="0.7" />
        </Border>

        <Border Grid.Row="1" Padding="8 6 8 0">
            <WrapPanel>
                <Button Command="{Binding ClearAllCommand}" Height="32" Padding="14 0" Margin="0 0 10 8"
                        Background="#CC3333" Foreground="White" FontWeight="Bold" FontSize="13"
                        CornerRadius="4" BorderThickness="0"
                        VerticalContentAlignment="Center">
                    <StackPanel Orientation="Horizontal" Spacing="5">
                        <TextBlock Text="🔥" FontSize="13" />
                        <TextBlock Text="Limpar Tudo" />
                    </StackPanel>
                </Button>
                <Button Command="{Binding ClearApplicationCommand}" Height="32" Padding="14 0" Margin="0 0 10 8"
                        Background="{DynamicResource SystemAccentColor}" Foreground="White" FontWeight="SemiBold" FontSize="13"
                        CornerRadius="4" BorderThickness="0"
                        VerticalContentAlignment="Center">
                    <StackPanel Orientation="Horizontal" Spacing="5">
                        <TextBlock Text="🗑" FontSize="13" />
                        <TextBlock Text="Limpar Cache" />
                    </StackPanel>
                </Button>
                <Button Command="{Binding ClearConfigCommand}" Height="32" Padding="14 0" Margin="0 0 10 8"
                        Background="#3A3A3A" Foreground="#E0E0E0" FontSize="13"
                        CornerRadius="4" BorderThickness="0"
                        VerticalContentAlignment="Center">
                    <StackPanel Orientation="Horizontal" Spacing="5">
                        <TextBlock Text="⚙️" FontSize="13" />
                        <TextBlock Text="Config" />
                    </StackPanel>
                </Button>
                <Button Command="{Binding ClearRouteCommand}" Height="32" Padding="14 0" Margin="0 0 10 8"
                        Background="#3A3A3A" Foreground="#E0E0E0" FontSize="13"
                        CornerRadius="4" BorderThickness="0"
                        VerticalContentAlignment="Center">
                    <StackPanel Orientation="Horizontal" Spacing="5">
                        <TextBlock Text="🗺️" FontSize="13" />
                        <TextBlock Text="Rotas" />
                    </StackPanel>
                </Button>
                <Button Command="{Binding ClearViewCommand}" Height="32" Padding="14 0" Margin="0 0 10 8"
                        Background="#3A3A3A" Foreground="#E0E0E0" FontSize="13"
                        CornerRadius="4" BorderThickness="0"
                        VerticalContentAlignment="Center">
                    <StackPanel Orientation="Horizontal" Spacing="5">
                        <TextBlock Text="👁️" FontSize="13" />
                        <TextBlock Text="Views" />
                    </StackPanel>
                </Button>
                <Button Command="{Binding ClearEventCommand}" Height="32" Padding="14 0" Margin="0 0 10 8"
                        Background="#3A3A3A" Foreground="#E0E0E0" FontSize="13"
                        CornerRadius="4" BorderThickness="0"
                        VerticalContentAlignment="Center">
                    <StackPanel Orientation="Horizontal" Spacing="5">
                        <TextBlock Text="📅" FontSize="13" />
                        <TextBlock Text="Events" />
                    </StackPanel>
                </Button>
            </WrapPanel>
        </Border>

        <Grid Grid.Row="2" Margin="8" RowDefinitions="Auto,*">
            <Grid ColumnDefinitions="Auto,*,Auto">
                <TextBlock Text="Saída" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center" />
                <Button Grid.Column="2" Command="{Binding ClearOutputCommand}" Padding="8 4">
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <TextBlock Text="🗑" />
                        <TextBlock Text="Limpar" />
                    </StackPanel>
                </Button>
            </Grid>
            <TextBox Grid.Row="1" Text="{Binding OutputText}"
                     FontFamily="Consolas" FontSize="13"
                     Foreground="#D4D4D4" Background="#1E1E1E"
                     BorderBrush="#333333" BorderThickness="1"
                     IsReadOnly="True"
                     TextWrapping="Wrap"
                     AcceptsReturn="True"
                     Padding="8"
                     Margin="0 6 0 0">
                <TextBox.Styles>
                    <Style Selector="TextBox /template/ Border#border">
                        <Setter Property="Background" Value="#1E1E1E" />
                    </Style>
                    <Style Selector="TextBox:pointerover /template/ Border#border">
                        <Setter Property="Background" Value="#1E1E1E" />
                        <Setter Property="BorderBrush" Value="#333333" />
                    </Style>
                    <Style Selector="TextBox:focus /template/ Border#border">
                        <Setter Property="Background" Value="#1E1E1E" />
                        <Setter Property="BorderBrush" Value="#333333" />
                    </Style>
                </TextBox.Styles>
            </TextBox>
        </Grid>
    </Grid>

</UserControl>
