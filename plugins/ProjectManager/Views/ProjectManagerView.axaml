<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:LTools.ProjectManager.ViewModels"
             x:DataType="vm:ProjectManagerViewModel"
             x:Class="LTools.ProjectManager.Views.ProjectManagerView">

    <DockPanel>
        <Border DockPanel.Dock="Top" Padding="16" BorderBrush="#33000000" BorderThickness="0 0 0 1">
            <Grid ColumnDefinitions="*,Auto">
                <TextBlock Text="{Binding SearchPath}" VerticalAlignment="Center"
                           Opacity="0.6" TextTrimming="CharacterEllipsis" />
                <Button Grid.Column="1" Command="{Binding SelectFolderCommand}" Margin="8 0 0 0">
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <TextBlock Text="📂" />
                        <TextBlock Text="Selecionar Pasta" />
                    </StackPanel>
                </Button>
            </Grid>
        </Border>

        <Border DockPanel.Dock="Bottom" Padding="12 8" Opacity="0.5">
            <TextBlock Text="{Binding StatusMessage}" FontSize="12" />
        </Border>

        <ScrollViewer Padding="16">
            <StackPanel Spacing="12">
                <ItemsControl ItemsSource="{Binding Projects}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:ProjectItemViewModel">
                            <Border CornerRadius="8" Padding="16"
                                    BorderBrush="#33000000"
                                    BorderThickness="1"
                                    Background="#0A000000">
                                <Grid RowDefinitions="Auto,Auto" ColumnDefinitions="*,Auto">
                                    <TextBlock Text="{Binding Name}" FontSize="16" FontWeight="Bold" />
                                    <Button Grid.Column="1" Grid.RowSpan="2"
                                            Command="{Binding $parent[ItemsControl].DataContext.OpenProjectCommand}"
                                            CommandParameter="{Binding .}"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            FontSize="20"
                                            Content="📂"
                                            ToolTip.Tip="Abrir pasta" />

                                    <WrapPanel Grid.Row="1" Margin="0 8 0 0">
                                        <Border CornerRadius="4" Padding="6 2" Background="#1A0078D4" Margin="0 0 8 4">
                                            <TextBlock FontSize="11">
                                                <Run Text="Laravel " />
                                                <Run Text="{Binding LaravelVersion}" FontWeight="Bold" />
                                            </TextBlock>
                                        </Border>
                                        <Border CornerRadius="4" Padding="6 2" Background="#1A0078D4" Margin="0 0 8 4">
                                            <TextBlock FontSize="11">
                                                <Run Text="PHP " />
                                                <Run Text="{Binding PhpVersion}" FontWeight="Bold" />
                                            </TextBlock>
                                        </Border>
                                        <Border CornerRadius="4" Padding="6 2" Background="#1A0078D4" Margin="0 0 8 4">
                                            <TextBlock FontSize="11">
                                                <Run Text="DB: " />
                                                <Run Text="{Binding Database}" FontWeight="Bold" />
                                            </TextBlock>
                                        </Border>
                                        <Border CornerRadius="4" Padding="6 2" Background="#1A0078D4" Margin="0 0 8 4">
                                            <TextBlock FontSize="11">
                                                <Run Text="Ambiente: " />
                                                <Run Text="{Binding Environment}" FontWeight="Bold" />
                                            </TextBlock>
                                        </Border>
                                        <Border CornerRadius="4" Padding="6 2" Background="#1A0078D4" Margin="0 0 8 4">
                                            <TextBlock FontSize="11" Text="{Binding FormattedSize}" />
                                        </Border>
                                    </WrapPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </ScrollViewer>
    </DockPanel>

</UserControl>
