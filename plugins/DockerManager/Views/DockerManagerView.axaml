<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:LTools.DockerManager.ViewModels"
             x:DataType="vm:DockerManagerViewModel"
             x:Class="LTools.DockerManager.Views.DockerManagerView">

    <Grid RowDefinitions="Auto,Auto,*">
        <Border Padding="12 8" BorderBrush="#33000000" BorderThickness="0 0 0 1">
            <TextBlock Text="{Binding StatusMessage}" VerticalAlignment="Center" FontSize="12" Opacity="0.7" />
        </Border>

        <WrapPanel Grid.Row="1" Margin="8 8 8 0">
            <Button Command="{Binding UpCommand}" Height="32" Padding="14 0" Margin="0 0 10 8"
                    Background="#2496ED" Foreground="White" FontWeight="SemiBold" FontSize="13"
                    CornerRadius="4" BorderThickness="0"
                    VerticalContentAlignment="Center"
                    IsEnabled="{Binding HasDockerCompose}">
                <StackPanel Orientation="Horizontal" Spacing="5">
                    <TextBlock Text="▶️" FontSize="13" />
                    <TextBlock Text="Iniciar" />
                </StackPanel>
            </Button>
            <Button Command="{Binding StopCommand}" Height="32" Padding="14 0" Margin="0 0 10 8"
                    Background="#3A3A3A" Foreground="#E0E0E0" FontSize="13"
                    CornerRadius="4" BorderThickness="0"
                    VerticalContentAlignment="Center"
                    IsEnabled="{Binding HasDockerCompose}">
                <StackPanel Orientation="Horizontal" Spacing="5">
                    <TextBlock Text="⏹" FontSize="13" />
                    <TextBlock Text="Parar" />
                </StackPanel>
            </Button>
            <Button Command="{Binding DownCommand}" Height="32" Padding="14 0" Margin="0 0 10 8"
                    Background="#3A3A3A" Foreground="#E0E0E0" FontSize="13"
                    CornerRadius="4" BorderThickness="0"
                    VerticalContentAlignment="Center"
                    IsEnabled="{Binding HasDockerCompose}">
                <StackPanel Orientation="Horizontal" Spacing="5">
                    <TextBlock Text="🛑" FontSize="13" />
                    <TextBlock Text="Down" />
                </StackPanel>
            </Button>
            <Button Command="{Binding RebuildCommand}" Height="32" Padding="14 0" Margin="0 0 10 8"
                    Background="#3A3A3A" Foreground="#E0E0E0" FontSize="13"
                    CornerRadius="4" BorderThickness="0"
                    VerticalContentAlignment="Center"
                    IsEnabled="{Binding HasDockerCompose}">
                <StackPanel Orientation="Horizontal" Spacing="5">
                    <TextBlock Text="🔨" FontSize="13" />
                    <TextBlock Text="Rebuild" />
                </StackPanel>
            </Button>
            <Button Command="{Binding LogsCommand}" Height="32" Padding="14 0" Margin="0 0 10 8"
                    Background="#3A3A3A" Foreground="#E0E0E0" FontSize="13"
                    CornerRadius="4" BorderThickness="0"
                    VerticalContentAlignment="Center"
                    IsEnabled="{Binding HasDockerCompose}">
                <StackPanel Orientation="Horizontal" Spacing="5">
                    <TextBlock Text="📋" FontSize="13" />
                    <TextBlock Text="Logs" />
                </StackPanel>
            </Button>
            <Button Command="{Binding PsCommand}" Height="32" Padding="14 0" Margin="0 0 10 8"
                    Background="#3A3A3A" Foreground="#E0E0E0" FontSize="13"
                    CornerRadius="4" BorderThickness="0"
                    VerticalContentAlignment="Center"
                    IsEnabled="{Binding HasDockerCompose}">
                <StackPanel Orientation="Horizontal" Spacing="5">
                    <TextBlock Text="📊" FontSize="13" />
                    <TextBlock Text="Status" />
                </StackPanel>
            </Button>
        </WrapPanel>

        <Grid Grid.Row="2" Margin="8" RowDefinitions="Auto,*">
            <Grid ColumnDefinitions="Auto,*,Auto">
                <TextBlock Text="Saída" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center" />
                <Button Grid.Column="2" Command="{Binding ClearOutputCommand}" Height="28" Padding="10 0"
                        Background="#3A3A3A" Foreground="#E0E0E0" FontSize="12"
                        CornerRadius="4" BorderThickness="0"
                        VerticalContentAlignment="Center">
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <TextBlock Text="🗑" FontSize="12" />
                        <TextBlock Text="Limpar" />
                    </StackPanel>
                </Button>
            </Grid>
            <TextBox Grid.Row="1" Text="{Binding OutputText}"
                     FontFamily="Consolas" FontSize="13"
                     Foreground="#D4D4D4" Background="#1E1E1E"
                     BorderBrush="#333333" BorderThickness="1"
                     IsReadOnly="True"
                     TextWrapping="Wrap"
                     AcceptsReturn="True"
                     Padding="8"
                     Margin="0 6 0 0">
                <TextBox.Styles>
                    <Style Selector="TextBox /template/ Border#border">
                        <Setter Property="Background" Value="#1E1E1E" />
                    </Style>
                    <Style Selector="TextBox:pointerover /template/ Border#border">
                        <Setter Property="Background" Value="#1E1E1E" />
                        <Setter Property="BorderBrush" Value="#333333" />
                    </Style>
                    <Style Selector="TextBox:focus /template/ Border#border">
                        <Setter Property="Background" Value="#1E1E1E" />
                        <Setter Property="BorderBrush" Value="#333333" />
                    </Style>
                </TextBox.Styles>
            </TextBox>
        </Grid>
    </Grid>

</UserControl>