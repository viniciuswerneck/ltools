<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:LTools.DockerManager.ViewModels"
             x:DataType="vm:DockerManagerViewModel"
             x:Class="LTools.DockerManager.Views.DockerManagerView">

    <Grid RowDefinitions="Auto,Auto,*,Auto">
        <Border Padding="12 8" BorderBrush="#33000000" BorderThickness="0 0 0 1">
            <Grid ColumnDefinitions="*,Auto">
                <TextBlock Text="{Binding StatusMessage}" VerticalAlignment="Center" FontSize="12" Opacity="0.7" />
                <Button Grid.Column="1" Command="{Binding ClearOutputCommand}" Padding="8 4">
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <TextBlock Text="🗑" />
                        <TextBlock Text="Limpar" />
                    </StackPanel>
                </Button>
            </Grid>
        </Border>

        <WrapPanel Grid.Row="1" Margin="8 8 8 0">
            <Button Command="{Binding UpCommand}" Padding="12 6" FontWeight="Bold"
                    Background="#2496ED" Foreground="White"
                    IsEnabled="{Binding HasDockerCompose}">
                <StackPanel Orientation="Horizontal" Spacing="4">
                    <TextBlock Text="▶️" />
                    <TextBlock Text="Iniciar" />
                </StackPanel>
            </Button>
            <Button Command="{Binding StopCommand}" Padding="12 6"
                    IsEnabled="{Binding HasDockerCompose}">
                <StackPanel Orientation="Horizontal" Spacing="4">
                    <TextBlock Text="⏹" />
                    <TextBlock Text="Parar" />
                </StackPanel>
            </Button>
            <Button Command="{Binding DownCommand}" Padding="12 6"
                    IsEnabled="{Binding HasDockerCompose}">
                <StackPanel Orientation="Horizontal" Spacing="4">
                    <TextBlock Text="🛑" />
                    <TextBlock Text="Down" />
                </StackPanel>
            </Button>
            <Button Command="{Binding RebuildCommand}" Padding="12 6"
                    IsEnabled="{Binding HasDockerCompose}">
                <StackPanel Orientation="Horizontal" Spacing="4">
                    <TextBlock Text="🔨" />
                    <TextBlock Text="Rebuild" />
                </StackPanel>
            </Button>
            <Button Command="{Binding LogsCommand}" Padding="12 6"
                    IsEnabled="{Binding HasDockerCompose}">
                <StackPanel Orientation="Horizontal" Spacing="4">
                    <TextBlock Text="📋" />
                    <TextBlock Text="Logs" />
                </StackPanel>
            </Button>
            <Button Command="{Binding PsCommand}" Padding="12 6"
                    IsEnabled="{Binding HasDockerCompose}">
                <StackPanel Orientation="Horizontal" Spacing="4">
                    <TextBlock Text="📊" />
                    <TextBlock Text="Status" />
                </StackPanel>
            </Button>
        </WrapPanel>

        <Border Grid.Row="2" Margin="8" CornerRadius="4" Background="#1E1E1E"
                BorderBrush="#333333" BorderThickness="1">
            <ScrollViewer>
                <TextBlock Text="{Binding OutputText}"
                           FontFamily="Consolas" FontSize="13"
                           Foreground="#D4D4D4"
                           TextWrapping="Wrap"
                           Padding="12" />
            </ScrollViewer>
        </Border>

        <Border Grid.Row="3" Padding="12 6" BorderBrush="#33000000" BorderThickness="0 1 0 0">
            <TextBlock Text="{Binding StatusMessage}" FontSize="12" Opacity="0.6" VerticalAlignment="Center" />
        </Border>
    </Grid>

</UserControl>