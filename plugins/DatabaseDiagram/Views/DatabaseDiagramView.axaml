<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:LTools.DatabaseDiagram.ViewModels"
             x:DataType="vm:DatabaseDiagramViewModel"
             x:Class="LTools.DatabaseDiagram.Views.DatabaseDiagramView">

    <Grid RowDefinitions="Auto,*">
        <Border Padding="12 8" BorderBrush="{DynamicResource BorderColor}" BorderThickness="0 0 0 1">
            <TextBlock Text="{Binding StatusMessage}" VerticalAlignment="Center" FontSize="12" Opacity="0.7" />
        </Border>

        <Grid Grid.Row="1" ColumnDefinitions="300,*,300" Margin="8">
            <Border BorderBrush="{DynamicResource BorderColor}" BorderThickness="0 0 1 0" Padding="8">
                <Grid RowDefinitions="Auto,*">
                    <TextBlock Text="Tabelas" FontWeight="SemiBold" FontSize="14" Margin="0 0 0 8" />
                    <ListBox Grid.Row="1" ItemsSource="{Binding Tables}" SelectedItem="{Binding SelectedTable}"
                             BorderThickness="0" Background="Transparent">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="8 4" Margin="0 0 0 2" CornerRadius="4" Background="{DynamicResource AccentBg}">
                                    <StackPanel>
                                        <TextBlock Text="{Binding Name}" FontSize="13" FontWeight="SemiBold" />
                                        <TextBlock Text="{Binding Columns.Count, StringFormat='{}{0} colunas'}"
                                                   FontSize="11" Opacity="0.6" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>

            <Border Grid.Column="1" Margin="8 0" Padding="8" CornerRadius="4" Background="{DynamicResource AccentBg}">
                <Grid RowDefinitions="Auto,*,Auto">
                    <TextBlock Text="{Binding SelectedTable.Name, TargetNullValue='Selecione uma tabela'}"
                               FontSize="16" FontWeight="Bold" Margin="0 0 0 8" />
                    <ListBox Grid.Row="1" ItemsSource="{Binding SelectedTable.Columns}"
                             BorderThickness="0" Background="Transparent">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="6 3" Margin="0 0 0 1" CornerRadius="2" Background="{DynamicResource OverlayLight}">
                                    <Grid ColumnDefinitions="Auto,*,Auto">
                                        <TextBlock Text="{Binding Name}" FontSize="13" FontWeight="SemiBold" />
                                        <TextBlock Grid.Column="1" Text="{Binding Type}" FontSize="11" Opacity="0.6" Margin="8 0" />
                                        <TextBlock Grid.Column="2" Text="{Binding IsNullable, StringFormat='{}NULL'}"
                                                   FontSize="10" Opacity="0.4" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                    <TextBlock Grid.Row="2" Text="{Binding SelectedTable.Relationships.Count, StringFormat='Relacionamentos: {0}'}"
                               FontSize="12" Opacity="0.7" Margin="0 8 0 0" />
                </Grid>
            </Border>

            <Border Grid.Column="2" BorderBrush="{DynamicResource BorderColor}" BorderThickness="1 0 0 0" Padding="8">
                <Grid RowDefinitions="Auto,*">
                    <TextBlock Text="Relacionamentos" FontWeight="SemiBold" FontSize="14" Margin="0 0 0 8" />
                    <ScrollViewer Grid.Row="1">
                        <ItemsControl ItemsSource="{Binding SelectedTable.Relationships}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="6 4" Margin="0 0 0 2" CornerRadius="4" Background="{DynamicResource AccentBg}">
                                        <StackPanel>
                                            <TextBlock FontSize="12">
                                                <Run Text="{Binding FromTable}" FontWeight="Bold" />
                                                <Run Text="." />
                                                <Run Text="{Binding FromColumn}" />
                                            </TextBlock>
                                            <TextBlock Text="⬇" FontSize="14" HorizontalAlignment="Center" />
                                            <TextBlock FontSize="12">
                                                <Run Text="{Binding ToTable}" FontWeight="Bold" />
                                                <Run Text="." />
                                                <Run Text="{Binding ToColumn}" />
                                            </TextBlock>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>
    </Grid>

</UserControl>