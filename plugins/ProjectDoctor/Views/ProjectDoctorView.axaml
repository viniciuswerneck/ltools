<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:LTools.ProjectDoctor.ViewModels"
             x:DataType="vm:ProjectDoctorViewModel"
             x:Class="LTools.ProjectDoctor.Views.ProjectDoctorView">

    <Grid RowDefinitions="Auto,Auto,*">
        <Border Padding="12 8" BorderBrush="#33000000" BorderThickness="0 0 0 1">
            <Grid ColumnDefinitions="*,Auto">
                <TextBlock Text="{Binding StatusMessage}" VerticalAlignment="Center" FontSize="12" Opacity="0.7" />
                <Button Grid.Column="1" Command="{Binding ClearResultsCommand}" Height="28" Padding="10 0"
                        Background="#3A3A3A" Foreground="#E0E0E0" FontSize="12"
                        CornerRadius="4" BorderThickness="0"
                        VerticalContentAlignment="Center">
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <TextBlock Text="🗑" FontSize="12" />
                        <TextBlock Text="Limpar" />
                    </StackPanel>
                </Button>
            </Grid>
        </Border>

        <Border Grid.Row="1" Margin="8 8 8 0" Padding="16" CornerRadius="8" Background="#1A0078D4">
            <Grid ColumnDefinitions="Auto,*,Auto">
                <Button Command="{Binding RunDiagnosticsCommand}" Height="32" Padding="14 0" FontSize="13" FontWeight="SemiBold"
                        Background="{DynamicResource SystemAccentColor}" Foreground="White"
                        CornerRadius="4" BorderThickness="0"
                        VerticalContentAlignment="Center">
                    <StackPanel Orientation="Horizontal" Spacing="5">
                        <TextBlock Text="🩺" FontSize="13" />
                        <TextBlock Text="Executar Diagnóstico" />
                    </StackPanel>
                </Button>

                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center" Spacing="12" VerticalAlignment="Center">
                    <Border CornerRadius="8" Padding="16 8" Background="#22000000" MinWidth="80">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="{Binding HealthScore, StringFormat='{}{0}%'}" FontSize="28" FontWeight="Bold"
                                       HorizontalAlignment="Center" />
                            <TextBlock Text="Saúde" FontSize="11" Opacity="0.7" HorizontalAlignment="Center" />
                        </StackPanel>
                    </Border>
                    <TextBlock Text="{Binding HealthLabel}" FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center" />
                </StackPanel>
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="2" Margin="8">
            <ItemsControl ItemsSource="{Binding Checks}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Padding="12 8" Margin="0 0 0 4" CornerRadius="4"
                                BorderBrush="#22000000" BorderThickness="0 0 0 1">
                            <Grid ColumnDefinitions="20,*,Auto" RowDefinitions="Auto,Auto">
                                <TextBlock Text="✅" FontSize="14" VerticalAlignment="Center" />
                                <StackPanel Grid.Column="1" Margin="8 0">
                                    <TextBlock Text="{Binding Name}" FontSize="14" FontWeight="SemiBold" />
                                    <TextBlock Text="{Binding Message}" FontSize="12" Opacity="0.7" />
                                </StackPanel>
                                <Border Grid.Column="2" CornerRadius="3" Padding="6 2" VerticalAlignment="Center"
                                        Background="#33000000">
                                    <TextBlock Text="{Binding Category}" FontSize="10" Opacity="0.6" />
                                </Border>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>

</UserControl>