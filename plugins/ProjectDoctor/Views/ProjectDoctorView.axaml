<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:LTools.ProjectDoctor.ViewModels"
             xmlns:models="using:LTools.ProjectDoctor.Models"
             x:DataType="vm:ProjectDoctorViewModel"
             x:Class="LTools.ProjectDoctor.Views.ProjectDoctorView"
             x:Name="root">

    <Grid RowDefinitions="Auto,Auto,Auto,*">

        <!-- Row 0: Status bar -->
        <Border Padding="12 8" BorderBrush="{DynamicResource BorderColor}" BorderThickness="0 0 0 1">
            <Grid ColumnDefinitions="Auto,*,Auto,Auto">
                <Ellipse Width="10" Height="10" Fill="#FF9800"
                         IsVisible="{Binding IsRunning}" VerticalAlignment="Center">
                    <Ellipse.Styles>
                        <Style Selector="Ellipse">
                            <Setter Property="Opacity" Value="1" />
                        </Style>
                    </Ellipse.Styles>
                </Ellipse>
                <TextBlock Grid.Column="1" Text="{Binding StatusMessage}"
                           VerticalAlignment="Center" FontSize="12" Opacity="0.7"
                           Margin="8 0 0 0" />
                <Button Grid.Column="3" Command="{Binding ClearResultsCommand}" Classes="Small Secondary">
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <TextBlock Text="&#x1F5D1;" FontSize="12" />
                        <TextBlock Text="Limpar" />
                    </StackPanel>
                </Button>
            </Grid>
        </Border>

        <!-- Row 1: Actions + Health Score -->
        <Border Grid.Row="1" Margin="8 8 8 0" Padding="16" CornerRadius="8" Background="{DynamicResource AccentBg}">
            <Grid ColumnDefinitions="Auto,Auto,*,Auto">
                <Button Command="{Binding RunDiagnosticsCommand}" Classes="Primary">
                    <StackPanel Orientation="Horizontal" Spacing="5">
                        <TextBlock Text="&#x1FA7A;" FontSize="13" />
                        <TextBlock Text="Diagnosticar" />
                    </StackPanel>
                </Button>

                <Button Grid.Column="1" Command="{Binding FixAllCommand}" Classes="Success" Margin="8 0 0 0"
                        IsVisible="{Binding NotRunning}">
                    <StackPanel Orientation="Horizontal" Spacing="5">
                        <TextBlock Text="&#x1F527;" FontSize="13" />
                        <TextBlock Text="Corrigir Tudo (Seguro)" />
                    </StackPanel>
                </Button>

                <StackPanel Grid.Column="3" Orientation="Horizontal" Spacing="12">
                    <Border CornerRadius="8" Padding="16 8" Background="#22000000" MinWidth="80">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="{Binding HealthScore, StringFormat='{}{0}%'}" FontSize="28" FontWeight="Bold"
                                       HorizontalAlignment="Center" Foreground="{Binding HealthColor}" />
                            <TextBlock Text="Saúde" FontSize="11" Opacity="0.7" HorizontalAlignment="Center" />
                        </StackPanel>
                    </Border>
                    <TextBlock Text="{Binding HealthLabel}" FontSize="16" FontWeight="SemiBold"
                               VerticalAlignment="Center" Foreground="{Binding HealthColor}" Margin="12 0 0 0" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- Row 2: Summary counts + Progress -->
        <Border Grid.Row="2" Margin="8 4 8 0" Padding="8 4" CornerRadius="4" Background="{DynamicResource OverlayLight}">
            <Grid ColumnDefinitions="Auto,*,Auto">
                <StackPanel Orientation="Horizontal" Spacing="16" HorizontalAlignment="Center">
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <TextBlock Text="&#x2705;" FontSize="11" />
                        <TextBlock Text="{Binding PassedCount, StringFormat='{}OK: {0}'}" FontSize="11" Opacity="0.6" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <TextBlock Text="&#x26A0;&#xFE0F;" FontSize="11" />
                        <TextBlock Text="{Binding WarningCount, StringFormat='{}Alerta: {0}'}" FontSize="11" Opacity="0.6" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <TextBlock Text="&#x274C;" FontSize="11" />
                        <TextBlock Text="{Binding FailedCount, StringFormat='{}Falha: {0}'}" FontSize="11" Opacity="0.6" />
                    </StackPanel>
                </StackPanel>

                <TextBlock Grid.Column="1" Text="{Binding CurrentCheckName}" FontSize="11" Opacity="0.5"
                           HorizontalAlignment="Right" VerticalAlignment="Center" />
            </Grid>
        </Border>

        <!-- Row 3: Check list with ScrollViewer -->
        <ScrollViewer Grid.Row="3" Margin="8"
                      VerticalScrollBarVisibility="Visible">
            <ScrollViewer.Styles>
                <Style Selector="ScrollBar">
                    <Setter Property="AllowAutoHide" Value="False"/>
                </Style>
            </ScrollViewer.Styles>
            <ItemsControl ItemsSource="{Binding CheckGroups}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="models:DoctorGroup">
                        <StackPanel Margin="0 0 0 12">
                            <Border Padding="10 6" CornerRadius="4" Background="{DynamicResource AccentBg}" Margin="0 0 0 4">
                                <TextBlock Text="{Binding Category}" FontSize="12" FontWeight="Bold" />
                            </Border>

                            <ItemsControl ItemsSource="{Binding Items}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="models:DoctorCheck">
                                        <Border Padding="10 6" Margin="0 1 0 0" CornerRadius="4"
                                                Background="{DynamicResource OverlayLight}">
                                            <Grid ColumnDefinitions="20,*,Auto,Auto">
                                                <TextBlock Text="{Binding Icon}" FontSize="14"
                                                           VerticalAlignment="Top" Margin="0 2 0 0" />

                                                <StackPanel Grid.Column="1" Margin="8 0">
                                                    <Grid ColumnDefinitions="Auto,*">
                                                        <TextBlock Text="{Binding Name}" FontSize="13" FontWeight="SemiBold" />
                                                        <TextBlock Grid.Column="1" Text="{Binding SeverityIcon}"
                                                                   FontSize="10" Margin="6 2 0 0" />
                                                    </Grid>
                                                    <TextBlock Text="{Binding WhatItChecks}" FontSize="11" Opacity="0.6" />
                                                    <TextBlock Text="{Binding Message}" FontSize="12"
                                                               Margin="0 2 0 0" />
                                                    <TextBlock Text="{Binding Suggestion}" FontSize="11"
                                                               Opacity="0.5" FontStyle="Italic" Margin="0 1 0 0"
                                                               TextWrapping="Wrap" />
                                                </StackPanel>

                                                <Button Grid.Column="3"
                                                        Command="{Binding #root.DataContext.FixCheckCommand}"
                                                        CommandParameter="{Binding}"
                                                        IsVisible="{Binding ShowFixButton}"
                                                        Classes="Small"
                                                        Background="#E67E22" Foreground="White"
                                                        VerticalAlignment="Top" Margin="4 0 0 0">
                                                    <StackPanel Orientation="Horizontal" Spacing="4">
                                                        <TextBlock Text="&#x1F527;" FontSize="11" />
                                                        <TextBlock Text="{Binding FixButtonText}" />
                                                    </StackPanel>
                                                </Button>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>

</UserControl>
