<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:LTools.RouteExplorer.ViewModels"
             xmlns:models="using:LTools.RouteExplorer.Models"
             x:DataType="vm:RouteExplorerViewModel"
             x:Class="LTools.RouteExplorer.Views.RouteExplorerView">

    <Grid RowDefinitions="Auto,Auto,Auto,*,Auto">

        <!-- ═══ ROW 0: STATUS BAR ═══ -->
        <Border Padding="12 8" BorderBrush="#33FFFFFF" BorderThickness="0 0 0 1">
            <Grid ColumnDefinitions="*,Auto,Auto,Auto">
                <TextBlock Text="{Binding StatusMessage}" VerticalAlignment="Center"
                           FontSize="12" Opacity="0.8" TextTrimming="CharacterEllipsis" />

                <TextBlock Grid.Column="1" VerticalAlignment="Center" FontSize="11"
                           Opacity="0.5" Margin="0 0 12 0"
                           Text="{Binding MethodBreakdown}" />

                <Button Grid.Column="2" Command="{Binding ExportCsvCommand}" Height="28" Padding="10 0" Margin="0 0 4 0"
                        Background="#3A3A3A" Foreground="#E0E0E0" FontSize="12"
                        CornerRadius="4" BorderThickness="0"
                        VerticalContentAlignment="Center"
                        ToolTip.Tip="Exportar rotas para CSV">
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <TextBlock Text="📤" FontSize="12" />
                        <TextBlock Text="CSV" FontSize="12" />
                    </StackPanel>
                </Button>

                <Button Grid.Column="3" Command="{Binding LoadRoutesCommand}" Height="28" Padding="10 0"
                        Background="#3A3A3A" Foreground="#E0E0E0" FontSize="12"
                        CornerRadius="4" BorderThickness="0"
                        VerticalContentAlignment="Center"
                        ToolTip.Tip="Recarregar rotas">
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <TextBlock Text="🔄" FontSize="12" />
                        <TextBlock Text="Refresh" FontSize="12" />
                    </StackPanel>
                </Button>
            </Grid>
        </Border>

        <!-- ═══ ROW 1: METHOD FILTER ═══ -->
        <Border Grid.Row="1" Padding="12 6" Background="#1A1A1A" BorderBrush="#33FFFFFF" BorderThickness="0 0 0 1">
            <StackPanel Orientation="Horizontal" Spacing="4">
                <TextBlock Text="Methods:" FontSize="11" VerticalAlignment="Center" Opacity="0.5" Margin="0 0 4 0" />

                <ToggleButton IsChecked="{Binding FilterGet}" Height="26" Padding="10 0" FontSize="11"
                              CornerRadius="3" BorderThickness="0"
                              Background="#1A4C9AFF" Foreground="#4C9AFF"
                              VerticalContentAlignment="Center" Cursor="Hand"
                              ToolTip.Tip="Filtrar por GET">
                    <TextBlock Text="GET" FontSize="11" FontWeight="SemiBold" />
                </ToggleButton>

                <ToggleButton IsChecked="{Binding FilterPost}" Height="26" Padding="10 0" FontSize="11"
                              CornerRadius="3" BorderThickness="0"
                              Background="#1A5CBD6E" Foreground="#5CBD6E"
                              VerticalContentAlignment="Center" Cursor="Hand"
                              ToolTip.Tip="Filtrar por POST">
                    <TextBlock Text="POST" FontSize="11" FontWeight="SemiBold" />
                </ToggleButton>

                <ToggleButton IsChecked="{Binding FilterPut}" Height="26" Padding="10 0" FontSize="11"
                              CornerRadius="3" BorderThickness="0"
                              Background="#1AFFC107" Foreground="#FFC107"
                              VerticalContentAlignment="Center" Cursor="Hand"
                              ToolTip.Tip="Filtrar por PUT">
                    <TextBlock Text="PUT" FontSize="11" FontWeight="SemiBold" />
                </ToggleButton>

                <ToggleButton IsChecked="{Binding FilterPatch}" Height="26" Padding="10 0" FontSize="11"
                              CornerRadius="3" BorderThickness="0"
                              Background="#1AFF9800" Foreground="#FF9800"
                              VerticalContentAlignment="Center" Cursor="Hand"
                              ToolTip.Tip="Filtrar por PATCH">
                    <TextBlock Text="PATCH" FontSize="11" FontWeight="SemiBold" />
                </ToggleButton>

                <ToggleButton IsChecked="{Binding FilterDelete}" Height="26" Padding="10 0" FontSize="11"
                              CornerRadius="3" BorderThickness="0"
                              Background="#1AF06A7A" Foreground="#F06A7A"
                              VerticalContentAlignment="Center" Cursor="Hand"
                              ToolTip.Tip="Filtrar por DELETE">
                    <TextBlock Text="DELETE" FontSize="11" FontWeight="SemiBold" />
                </ToggleButton>

                <ToggleButton IsChecked="{Binding FilterHead}" Height="26" Padding="10 0" FontSize="11"
                              CornerRadius="3" BorderThickness="0"
                              Background="#1A555555" Foreground="#999999"
                              VerticalContentAlignment="Center" Cursor="Hand"
                              ToolTip.Tip="Filtrar por HEAD">
                    <TextBlock Text="HEAD" FontSize="11" FontWeight="SemiBold" />
                </ToggleButton>

                <ToggleButton IsChecked="{Binding FilterOptions}" Height="26" Padding="10 0" FontSize="11"
                              CornerRadius="3" BorderThickness="0"
                              Background="#1A6F42C1" Foreground="#B388FF"
                              VerticalContentAlignment="Center" Cursor="Hand"
                              ToolTip.Tip="Filtrar por OPTIONS">
                    <TextBlock Text="OPTIONS" FontSize="11" FontWeight="SemiBold" />
                </ToggleButton>
            </StackPanel>
        </Border>

        <!-- ═══ ROW 2: SEARCH + GROUP MODE ═══ -->
        <Border Grid.Row="2" Padding="12 6" Background="#1A1A1A" BorderBrush="#33FFFFFF" BorderThickness="0 0 0 1">
            <Grid ColumnDefinitions="200,180,Auto,Auto,Auto,*">
                <TextBox Text="{Binding SearchText}" PlaceholderText="🔍 Buscar rotas..."
                         FontSize="12" Height="28" CornerRadius="4" Padding="8 0"
                         Background="#2A2A2A" Foreground="#E0E0E0"
                         BorderBrush="#444" />

                <TextBox Grid.Column="1" Text="{Binding MiddlewareFilter}" PlaceholderText="Filtrar middleware..."
                         FontSize="12" Height="28" CornerRadius="4" Padding="8 0" Margin="6 0 0 0"
                         Background="#2A2A2A" Foreground="#E0E0E0"
                         BorderBrush="#444" />

                <Button Grid.Column="2" Command="{Binding ClearFiltersCommand}" Height="28" Padding="8 0" Margin="6 0 0 0"
                        Background="#3A3A3A" Foreground="#E0E0E0" FontSize="11"
                        CornerRadius="4" BorderThickness="0" VerticalContentAlignment="Center"
                        ToolTip.Tip="Limpar todos os filtros">
                    <TextBlock Text="✕ Limpar" FontSize="11" />
                </Button>

                <ComboBox Grid.Column="3" SelectedIndex="{Binding SelectedGroupMode}" Margin="6 0 0 0"
                          Height="28" FontSize="11"
                          Background="#2A2A2A" Foreground="#E0E0E0" BorderBrush="#444">
                    <ComboBoxItem>Lista</ComboBoxItem>
                    <ComboBoxItem>Prefixo</ComboBoxItem>
                    <ComboBoxItem>Controller</ComboBoxItem>
                    <ComboBoxItem>Middleware</ComboBoxItem>
                    <ComboBoxItem>Domínio</ComboBoxItem>
                </ComboBox>

                <CheckBox Grid.Column="4" IsChecked="{Binding ShowDuplicates}" Content="Duplicatas"
                          Margin="8 0 0 0" VerticalAlignment="Center" FontSize="11"
                          ToolTip.Tip="Mostrar apenas URIs duplicadas" />

                <TextBlock Grid.Column="5" VerticalAlignment="Center" FontSize="11" Opacity="0.5"
                           HorizontalAlignment="Right" Margin="0 0 4 0">
                    <Run Text="{Binding FilteredCount}" />
                    <Run Text=" rota(s)" />
                </TextBlock>
            </Grid>
        </Border>

        <!-- ═══ ROW 3: CONTENT ═══ -->
        <Grid Grid.Row="3">

            <!-- No project -->
            <Border IsVisible="{Binding HasNoProject}" VerticalAlignment="Center" HorizontalAlignment="Center">
                <StackPanel Spacing="8" HorizontalAlignment="Center">
                    <TextBlock Text="📂" FontSize="40" HorizontalAlignment="Center" />
                    <TextBlock Text="Nenhum projeto selecionado"
                               FontSize="16" FontWeight="SemiBold" HorizontalAlignment="Center" />
                    <TextBlock Text="Selecione um projeto na barra superior para ver as rotas."
                               FontSize="12" Opacity="0.6" HorizontalAlignment="Center" />
                </StackPanel>
            </Border>

            <!-- No routes -->
            <Border IsVisible="{Binding HasNoRoutes}" VerticalAlignment="Center" HorizontalAlignment="Center">
                <StackPanel Spacing="8" HorizontalAlignment="Center">
                    <TextBlock Text="🗺️" FontSize="40" HorizontalAlignment="Center" />
                    <TextBlock Text="Nenhuma rota encontrada"
                               FontSize="16" FontWeight="SemiBold" HorizontalAlignment="Center" />
                    <TextBlock Text="Verifique se o projeto tem arquivos de rota em routes/"
                               FontSize="12" Opacity="0.6" HorizontalAlignment="Center" />
                </StackPanel>
            </Border>

            <!-- Flat list view -->
            <ListBox ItemsSource="{Binding FilteredRoutes}"
                     SelectedItem="{Binding SelectedRoute}"
                     IsVisible="{Binding IsFlatView}"
                     BorderThickness="0" Background="Transparent">
                <ListBox.ItemTemplate>
                    <DataTemplate x:DataType="models:RouteInfo">
                        <Border Padding="8 4" Margin="2 1" CornerRadius="4" Background="#1E1E1E">
                            <Border.Styles>
                                <Style Selector="Border:pointerover">
                                    <Setter Property="Background" Value="#2A2A2A" />
                                </Style>
                            </Border.Styles>
                            <Grid ColumnDefinitions="65,*,Auto,Auto" RowDefinitions="Auto,Auto" ColumnSpacing="8">
                                <!-- Method badge -->
                                <Border CornerRadius="3" Padding="6 2" VerticalAlignment="Center"
                                        HorizontalAlignment="Center"
                                        Background="{Binding MethodBadgeBg}">
                                    <TextBlock Text="{Binding Method}" FontSize="11" FontWeight="Bold"
                                               Foreground="{Binding MethodBadgeTextColor}" />
                                </Border>

                                <!-- URI + Name -->
                                <TextBlock Grid.Column="1" FontSize="14" FontWeight="SemiBold"
                                           Text="{Binding Uri}" VerticalAlignment="Center" />

                                <TextBlock Grid.Column="2" Text="{Binding Name}" FontSize="11"
                                           Opacity="0.6" VerticalAlignment="Center" Margin="8 0" />

                                <TextBlock Grid.Column="3" Text="{Binding Domain}" FontSize="10"
                                           Opacity="0.4" VerticalAlignment="Center"
                                           IsVisible="{Binding HasDomain}" />

                                <TextBlock Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="3"
                                           Text="{Binding Action}" FontSize="11" Opacity="0.4" />
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <!-- Grouped view -->
            <ScrollViewer IsVisible="{Binding IsGroupedView}">
                <ItemsControl ItemsSource="{Binding RouteGroups}" Margin="4">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:RouteGroup">
                            <Border Margin="0 0 0 4" CornerRadius="6" Background="#1A1A1A" Padding="8">
                                <StackPanel Spacing="4">
                                    <TextBlock FontSize="13" FontWeight="SemiBold" Opacity="0.8">
                                        <Run Text="{Binding Name}" />
                                        <Run Text=" (" />
                                        <Run Text="{Binding Count}" />
                                        <Run Text=")" />
                                    </TextBlock>

                                    <ItemsControl ItemsSource="{Binding Routes}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate x:DataType="models:RouteInfo">
                                                <Border Padding="8 3" CornerRadius="3" Margin="0 1"
                                                        Background="#2A2A2A">
                                                    <Grid ColumnDefinitions="55,*,Auto" ColumnSpacing="6">
                                                        <Border CornerRadius="2" Padding="4 1"
                                                                Background="{Binding MethodBadgeBg}"
                                                                HorizontalAlignment="Center">
                                                            <TextBlock Text="{Binding Method}" FontSize="10"
                                                                       FontWeight="Bold"
                                                                       Foreground="{Binding MethodBadgeTextColor}" />
                                                        </Border>

                                                        <TextBlock Grid.Column="1" Text="{Binding Uri}"
                                                                   FontSize="12" VerticalAlignment="Center" />

                                                        <TextBlock Grid.Column="2" Text="{Binding Action}"
                                                                   FontSize="10" Opacity="0.4"
                                                                   VerticalAlignment="Center" />
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

        </Grid>

        <!-- ═══ ROW 4: DETAIL PANEL ═══ -->
        <Border Grid.Row="4" Padding="12 8" BorderBrush="#33FFFFFF" BorderThickness="0 1 0 0"
                Background="#1A1A1A" IsVisible="{Binding IsDetailVisible}" MaxHeight="200">
            <Grid RowDefinitions="Auto,*" ColumnDefinitions="*,Auto">
                <TextBlock Text="Detalhes da Rota" FontSize="12" FontWeight="SemiBold" Opacity="0.7" />
                <Button Grid.Column="1" Command="{Binding CopySelectedRouteCommand}"
                        Height="24" Padding="6 0" FontSize="10"
                        Background="#3A3A3A" Foreground="#E0E0E0"
                        CornerRadius="3" BorderThickness="0"
                        VerticalContentAlignment="Center"
                        ToolTip.Tip="Copiar rota">
                    <StackPanel Orientation="Horizontal" Spacing="3">
                        <TextBlock Text="📋" FontSize="10" />
                        <TextBlock Text="Copiar" FontSize="10" />
                    </StackPanel>
                </Button>
                <ScrollViewer Grid.Row="1" Grid.ColumnSpan="2" Margin="0 4 0 0">
                    <TextBox Text="{Binding DetailContent}"
                             FontFamily="Consolas" FontSize="12"
                             Foreground="#D4D4D4" Background="Transparent"
                             BorderThickness="0" IsReadOnly="True"
                             Focusable="False" TextWrapping="Wrap"
                             Padding="4" />
                </ScrollViewer>
            </Grid>
        </Border>

    </Grid>

</UserControl>
