<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:LTools.ArtisanGui.ViewModels"
             xmlns:models="using:LTools.ArtisanGui.Models"
             x:DataType="vm:ArtisanGuiViewModel"
             x:Class="LTools.ArtisanGui.Views.ArtisanGuiView">

    <Grid RowDefinitions="Auto,*" ColumnDefinitions="300,*">
        <Border Grid.ColumnSpan="2" Padding="12 8" BorderBrush="#33000000" BorderThickness="0 0 0 1">
            <Grid ColumnDefinitions="Auto,Auto,*,Auto">
                <Button Command="{Binding SelectProjectCommand}" Padding="8 4" Margin="0 0 8 0">
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <TextBlock Text="📂" />
                        <TextBlock Text="{Binding ProjectName, TargetNullValue='Selecionar Projeto'}" />
                    </StackPanel>
                </Button>
                <TextBlock Grid.Column="1" Text="{Binding StatusMessage}" VerticalAlignment="Center" FontSize="12" Opacity="0.7" />
                <Button Grid.Column="3" Command="{Binding ClearOutputCommand}" Padding="8 4">
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <TextBlock Text="🗑" />
                        <TextBlock Text="Limpar" />
                    </StackPanel>
                </Button>
            </Grid>
        </Border>

        <Border Grid.Row="1" BorderBrush="#33000000" BorderThickness="0 0 1 0">
            <DockPanel>
                <Border DockPanel.Dock="Top" Padding="8" BorderBrush="#22000000" BorderThickness="0 0 0 1">
                    <TextBox Text="{Binding SearchText}" PlaceholderText="Pesquisar comandos..."
                             FontSize="13" Padding="8" />
                </Border>

                <ListBox ItemsSource="{Binding FilteredCommands}"
                         SelectedItem="{Binding SelectedCommand}"
                         BorderThickness="0"
                         Background="Transparent">
                    <ListBox.ItemTemplate>
                        <DataTemplate x:DataType="models:ArtisanCommand">
                            <StackPanel Margin="8 4">
                                <TextBlock Text="{Binding Name}" FontSize="13" FontWeight="SemiBold" />
                                <TextBlock Text="{Binding Description}" FontSize="11" Opacity="0.6"
                                           TextTrimming="CharacterEllipsis" MaxWidth="240" />
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>
        </Border>

        <Border Grid.Row="1" Grid.Column="1">
            <DockPanel>
                <Border DockPanel.Dock="Bottom" Padding="12" BorderBrush="#33000000" BorderThickness="0 1 0 0">
                    <StackPanel Spacing="8">
                        <TextBox Text="{Binding CustomCommand}" PlaceholderText="Comando (ex: route:list) — ou selecione na lista"
                                 FontSize="13" Padding="8" />
                        <TextBox Text="{Binding ArgumentValues}" PlaceholderText="Argumentos (ex: --force --name=Teste)"
                                 FontSize="13" Padding="8" />
                        <Button Command="{Binding ExecuteCommand}"
                                Foreground="White"
                                FontWeight="Bold"
                                Padding="8"
                                Background="{DynamicResource SystemAccentColor}">
                            <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Center">
                                <TextBlock Text="▶" />
                                <TextBlock Text="Executar" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Border>

                <ScrollViewer Padding="12">
                    <StackPanel Spacing="12">
                        <TextBlock Text="{Binding SelectedCommand.Name, TargetNullValue='Selecione um comando'}"
                                   FontSize="18" FontWeight="Bold" />
                        <TextBlock Text="{Binding SelectedCommand.Description, TargetNullValue=''}"
                                   FontSize="13" Opacity="0.7" />

                        <Border CornerRadius="4" Background="#1E1E1E" Padding="12"
                                BorderBrush="#333333" BorderThickness="1">
                            <ScrollViewer MaxHeight="300">
                                <TextBlock Text="{Binding OutputText}"
                                           FontFamily="Consolas"
                                           FontSize="13"
                                           Foreground="#D4D4D4"
                                           TextWrapping="Wrap" />
                            </ScrollViewer>
                        </Border>

                        <TextBlock Text="Histórico" FontSize="13" FontWeight="SemiBold" />
                        <ItemsControl ItemsSource="{Binding History}" MaxHeight="150">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="models:CommandHistory">
                                    <Border Padding="8 4" BorderBrush="#22000000" BorderThickness="0 0 0 1">
                                        <Grid ColumnDefinitions="Auto,*">
                                            <TextBlock Text="{Binding Command}" FontWeight="Bold" FontSize="12" />
                                            <TextBlock Grid.Column="1" Text="{Binding Arguments}" FontSize="11" Opacity="0.6" Margin="8 0 0 0" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </ScrollViewer>
            </DockPanel>
        </Border>
    </Grid>

</UserControl>
