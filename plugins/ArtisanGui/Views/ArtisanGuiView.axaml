<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:LTools.ArtisanGui.ViewModels"
             xmlns:models="using:LTools.ArtisanGui.Models"
             x:DataType="vm:ArtisanGuiViewModel"
             x:Class="LTools.ArtisanGui.Views.ArtisanGuiView">

    <Grid RowDefinitions="Auto,*" ColumnDefinitions="300,*">
        <Border Grid.ColumnSpan="2" Padding="12 8" BorderBrush="{DynamicResource BorderColor}" BorderThickness="0 0 0 1">
            <TextBlock Text="{Binding StatusMessage}" VerticalAlignment="Center" FontSize="12" Opacity="0.7" />
        </Border>

        <Border Grid.Row="1" BorderBrush="{DynamicResource BorderColor}" BorderThickness="0 0 1 0">
            <DockPanel>
                <Border DockPanel.Dock="Top" Padding="8" BorderBrush="#22000000" BorderThickness="0 0 0 1">
                    <TextBox Text="{Binding SearchText}" PlaceholderText="Pesquisar comandos..."
                             FontSize="13" Padding="8" />
                </Border>

                <ListBox ItemsSource="{Binding FilteredCommands}"
                         SelectedItem="{Binding SelectedCommand}"
                         BorderThickness="0"
                         Background="Transparent">
                    <ListBox.ItemTemplate>
                        <DataTemplate x:DataType="models:ArtisanCommand">
                            <StackPanel Margin="8 4">
                                <TextBlock Text="{Binding Name}" FontSize="13" FontWeight="SemiBold" />
                                <TextBlock Text="{Binding Description}" FontSize="11" Opacity="0.6"
                                           TextTrimming="CharacterEllipsis" MaxWidth="240" />
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>
        </Border>

        <Border Grid.Row="1" Grid.Column="1">
            <Grid RowDefinitions="*,Auto,Auto">
                <Grid RowDefinitions="Auto,Auto,*,Auto" Margin="12 12 12 0">
                    <TextBlock Text="{Binding SelectedCommand.Name, TargetNullValue='Selecione um comando'}"
                               FontSize="18" FontWeight="Bold" />
                    <TextBlock Grid.Row="1" Text="{Binding SelectedCommand.Description, TargetNullValue=''}"
                               FontSize="13" Opacity="0.7" Margin="0 0 0 8" />

                    <ScrollViewer Grid.Row="2" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                        <TextBox Text="{Binding OutputText}"
                                 Classes="Console"
                                 TextWrapping="Wrap" />
                    </ScrollViewer>

                    <Border Grid.Row="3" CornerRadius="4" Background="{DynamicResource SurfaceBackground}" Padding="8"
                            BorderBrush="{DynamicResource BorderLight}" BorderThickness="1"
                            MinHeight="60" MaxHeight="100"
                            Margin="0 8 0 0">
                        <Grid RowDefinitions="Auto,*">
                            <Grid ColumnDefinitions="Auto,*,Auto">
                                <TextBlock Text="Histórico" FontSize="12" FontWeight="SemiBold"
                                           Opacity="0.7" />
                                <Button Grid.Column="2" Command="{Binding ClearHistoryCommand}"
                                        Classes="Small Secondary" Padding="6 0" Height="20" FontSize="10"
                                        ToolTip.Tip="Limpar histórico">
                                    <TextBlock Text="✕ Limpar" FontSize="10" />
                                </Button>
                            </Grid>
                            <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Disabled">
                                <ItemsControl ItemsSource="{Binding History}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="models:CommandHistory">
                                            <Border Padding="6 3" BorderBrush="{DynamicResource BorderColor}" BorderThickness="0 0 0 1">
                                                <Grid ColumnDefinitions="Auto,*">
                                                    <TextBlock Text="{Binding Command}" FontWeight="Bold" FontSize="11"
                                                               Foreground="{DynamicResource ConsoleForeground}" />
                                                    <TextBlock Grid.Column="1" Text="{Binding Arguments}" FontSize="11"
                                                               Opacity="0.5" Margin="6 0 0 0" />
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </Grid>
                    </Border>
                </Grid>

                <Border Grid.Row="1" Padding="12" BorderBrush="{DynamicResource BorderColor}" BorderThickness="0 1 0 0"
                        Background="{Binding $parent[Window].Background}">
                    <StackPanel Spacing="8">
                        <TextBox Text="{Binding CustomCommand}" PlaceholderText="Digite o comando (autocomplete automático)"
                                 FontSize="13" Padding="8" />
                        <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="6">
                            <TextBox Text="{Binding ArgumentValues}" PlaceholderText="Argumentos (ex: --force --name=Teste)"
                                     FontSize="13" Padding="8" />
                            <Button Grid.Column="1" Command="{Binding CopyOutputCommand}" Classes="Small Secondary">
                                <StackPanel Orientation="Horizontal" Spacing="4">
                                    <TextBlock Text="📋" />
                                    <TextBlock Text="Copiar" />
                                </StackPanel>
                            </Button>
                            <Button Grid.Column="2" Command="{Binding ClearOutputCommand}" Classes="Small Secondary">
                                <StackPanel Orientation="Horizontal" Spacing="4">
                                    <TextBlock Text="🗑" />
                                    <TextBlock Text="Limpar" />
                                </StackPanel>
                            </Button>
                        </Grid>
                        <Button Command="{Binding ExecuteCommand}" Classes="Primary">
                            <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Center">
                                <TextBlock Text="▶" />
                                <TextBlock Text="Executar" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Border>

                <Border IsVisible="{Binding DangerWarningVisible}"
                        Background="{DynamicResource DangerColor}" CornerRadius="8" Padding="20"
                        HorizontalAlignment="Center" VerticalAlignment="Center"
                        Margin="40">
                    <StackPanel Spacing="12" HorizontalAlignment="Center">
                        <TextBlock Text="⚠️ ATENÇÃO" FontSize="18" FontWeight="Bold"
                                   Foreground="White" HorizontalAlignment="Center" />
                        <TextBlock FontSize="14" Foreground="White" TextWrapping="Wrap"
                                   HorizontalAlignment="Center">
                            <Run Text="Este comando pode causar PERDA DE DADOS:" FontWeight="Bold" />
                            <LineBreak />
                            <Run Text="{Binding DangerCommandName}" FontWeight="Bold" FontSize="16" />
                        </TextBlock>
                        <TextBlock Text="Tem certeza que deseja executar?" FontSize="14"
                                   Foreground="White" HorizontalAlignment="Center" />
                        <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                            <Button Command="{Binding ConfirmDangerCommand}" Padding="12 8"
                                    Background="#CC3333" Foreground="White" FontWeight="Bold">
                                <StackPanel Orientation="Horizontal" Spacing="4" HorizontalAlignment="Center">
                                    <TextBlock Text="⚠️" />
                                    <TextBlock Text="Sim, executar" />
                                </StackPanel>
                            </Button>
                            <Button Grid.Column="1" Command="{Binding CancelDangerCommand}"
                                    Padding="12 8" Background="{DynamicResource BorderLight}" Foreground="White">
                                <StackPanel Orientation="Horizontal" Spacing="4" HorizontalAlignment="Center">
                                    <TextBlock Text="✕" />
                                    <TextBlock Text="Cancelar" />
                                </StackPanel>
                            </Button>
                        </Grid>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>
    </Grid>

</UserControl>
