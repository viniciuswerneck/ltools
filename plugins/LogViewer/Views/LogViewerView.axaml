<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:LTools.LogViewer.ViewModels"
             x:DataType="vm:LogViewerViewModel"
             x:Class="LTools.LogViewer.Views.LogViewerView">

    <Grid RowDefinitions="Auto,Auto,*">
        <Border Padding="12 8" BorderBrush="#33000000" BorderThickness="0 0 0 1">
            <Grid ColumnDefinitions="Auto,Auto,*,Auto,Auto">
                <Button Command="{Binding SelectProjectCommand}" Padding="8 4" Margin="0 0 8 0">
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <TextBlock Text="📂" />
                        <TextBlock Text="{Binding ProjectName, TargetNullValue='Selecionar Projeto'}" />
                    </StackPanel>
                </Button>
                <TextBlock Grid.Column="1" Text="{Binding StatusMessage}" VerticalAlignment="Center" FontSize="12" Opacity="0.7" />
                <CheckBox Grid.Column="3" IsChecked="{Binding AutoRefresh}" Content="Auto-refresh" Margin="0 0 8 0" VerticalAlignment="Center" />
                <Button Grid.Column="4" Command="{Binding RefreshCommand}" Padding="8 4">
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <TextBlock Text="🔄" />
                        <TextBlock Text="Atualizar" />
                    </StackPanel>
                </Button>
            </Grid>
        </Border>

        <Grid Grid.Row="2" ColumnDefinitions="250,*" Margin="8">
            <Border BorderBrush="#33000000" BorderThickness="0 0 1 0" Padding="8">
                <StackPanel Spacing="4">
                    <TextBlock Text="Arquivos de Log" FontWeight="SemiBold" FontSize="14" Margin="0 0 0 8" />
                    <ListBox ItemsSource="{Binding LogFiles}" BorderThickness="0" Background="Transparent">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="8 4" Margin="0 0 0 2" CornerRadius="4"
                                        Background="#1A0078D4" PointerPressed="OpenLog">
                                    <Grid ColumnDefinitions="*,Auto">
                                        <StackPanel>
                                            <TextBlock Text="{Binding Name}" FontSize="13" FontWeight="SemiBold" />
                                            <TextBlock Text="{Binding SizeFormatted}" FontSize="11" Opacity="0.6" />
                                        </StackPanel>
                                        <TextBlock Grid.Column="1" Text="{Binding LastModified}"
                                                   FontSize="10" Opacity="0.4" VerticalAlignment="Center" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </StackPanel>
            </Border>

            <Border Grid.Column="1" Margin="8 0 0 0" CornerRadius="4" Background="#1E1E1E"
                    BorderBrush="#333333" BorderThickness="1">
                <ScrollViewer>
                    <TextBlock Text="{Binding LogContent}"
                               FontFamily="Consolas" FontSize="12"
                               Foreground="#D4D4D4"
                               TextWrapping="Wrap"
                               Padding="12" />
                </ScrollViewer>
            </Border>
        </Grid>
    </Grid>

</UserControl>