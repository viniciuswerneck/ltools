<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:LTools.LogViewer.ViewModels"
             xmlns:models="using:LTools.LogViewer.Models"
             x:DataType="vm:LogViewerViewModel"
             x:Class="LTools.LogViewer.Views.LogViewerView">

    <UserControl.Resources>
        <vm:DateTimeToOffsetConverter x:Key="DateConv" />
    </UserControl.Resources>

    <Grid RowDefinitions="Auto,Auto,*">

        <!-- Row 0: Status bar -->
        <Border Padding="12 8" BorderBrush="{DynamicResource BorderColor}" BorderThickness="0 0 0 1">
            <Grid ColumnDefinitions="*,Auto,Auto,Auto,Auto">
                <TextBlock Text="{Binding StatusMessage}" VerticalAlignment="Center" FontSize="12" Opacity="0.7" />

                <TextBlock Grid.Column="1" VerticalAlignment="Center" FontSize="12" Opacity="0.5" Margin="0 0 12 0"
                           IsVisible="{Binding ShowEntryCount}">
                    <Run Text="{Binding FilteredCount}" />
                    <Run Text="/" />
                    <Run Text="{Binding TotalEntries}" />
                    <Run Text=" entradas" />
                </TextBlock>

                <CheckBox Grid.Column="2" IsChecked="{Binding AutoRefresh}" Content="Auto" Margin="0 0 8 0"
                          VerticalAlignment="Center" FontSize="12" />

                <Button Grid.Column="3" Command="{Binding ToggleRawViewCommand}" Classes="Small Secondary" Margin="0 0 4 0"
                        ToolTip.Tip="Alternar visualização">
                    <TextBlock Text="📄 Raw" FontSize="12" />
                </Button>

                <StackPanel Grid.Column="4" Orientation="Horizontal" Spacing="4">
                    <Button Command="{Binding ClearLogCommand}" Classes="Small Secondary"
                            ToolTip.Tip="Limpar visualização">
                        <TextBlock Text="🗑" FontSize="12" />
                    </Button>
                    <Button Command="{Binding RefreshCommand}" Classes="Small Secondary"
                            ToolTip.Tip="Atualizar">
                        <TextBlock Text="🔄" FontSize="12" />
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Row 1: Filter bar -->
        <Border Grid.Row="1" Padding="12 6" BorderBrush="{DynamicResource BorderColor}" BorderThickness="0 0 0 1"
                Background="{DynamicResource SurfaceBackground}">
            <Grid ColumnDefinitions="*,Auto,100,100,100,Auto">
                <TextBox Text="{Binding SearchText}" PlaceholderText="Buscar no log..." FontSize="12" Height="28"
                         BorderThickness="1" CornerRadius="4" Padding="8 0"
                         Background="{DynamicResource CardBackground}" Foreground="#E0E0E0"
                         BorderBrush="#444" />

                <ComboBox Grid.Column="1" ItemsSource="{Binding LevelFilters}"
                          SelectedItem="{Binding SelectedLevel}"
                          Width="90" Height="28" Margin="6 0 0 0"
                          FontSize="12" Background="{DynamicResource CardBackground}" Foreground="#E0E0E0"
                          BorderBrush="#444" />

                <DatePicker Grid.Column="2" SelectedDate="{Binding StartDate, Converter={StaticResource DateConv}}"
                            Height="28" Margin="6 0 0 0" FontSize="11"
                            Background="{DynamicResource CardBackground}" Foreground="#E0E0E0"
                            BorderBrush="#444" />

                <TextBlock Grid.Column="3" Text="→" VerticalAlignment="Center" HorizontalAlignment="Center"
                           FontSize="14" Opacity="0.5" />

                <DatePicker Grid.Column="4" SelectedDate="{Binding EndDate, Converter={StaticResource DateConv}}"
                            Height="28" FontSize="11"
                            Background="{DynamicResource CardBackground}" Foreground="#E0E0E0"
                            BorderBrush="#444" />

                <StackPanel Grid.Column="5" Orientation="Horizontal" Spacing="4" Margin="6 0 0 0">
                    <Button Command="{Binding ClearFiltersCommand}" Classes="Small Secondary"
                            ToolTip.Tip="Limpar filtros">
                        <TextBlock Text="✕ Limpar" FontSize="11" />
                    </Button>
                    <Button Command="{Binding CopyFilteredCommand}" Classes="Small Secondary"
                            ToolTip.Tip="Copiar entradas filtradas">
                        <TextBlock Text="📋 Copiar" FontSize="11" />
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Row 2: Main content -->
        <Grid Grid.Row="2" ColumnDefinitions="250,*" Margin="8">

            <!-- Left Panel: File list -->
            <Border BorderBrush="{DynamicResource BorderColor}" BorderThickness="0 0 1 0" Padding="8">
                <StackPanel Spacing="4">
                    <TextBlock Text="Arquivos de Log" FontWeight="SemiBold" FontSize="14" Margin="0 0 0 8" />
                    <ListBox ItemsSource="{Binding LogFiles}" BorderThickness="0" Background="Transparent">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="8 4" Margin="0 0 0 2" CornerRadius="4"
                                        Background="{DynamicResource AccentBg}" PointerPressed="OpenLog">
                                    <Grid ColumnDefinitions="*,Auto">
                                        <StackPanel>
                                            <TextBlock Text="{Binding Name}" FontSize="13" FontWeight="SemiBold" />
                                            <TextBlock Text="{Binding SizeFormatted}" FontSize="11" Opacity="0.6" />
                                        </StackPanel>
                                        <TextBlock Grid.Column="1" Text="{Binding LastModified}"
                                                   FontSize="10" Opacity="0.4" VerticalAlignment="Center" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </StackPanel>
            </Border>

            <!-- Right Panel -->
            <Grid Grid.Column="1" Margin="8 0 0 0">

                <!-- Raw view -->
                <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto"
                              IsVisible="{Binding IsRawView}">
                    <TextBox Text="{Binding LogContent}"
                             Classes="Console"
                             TextWrapping="NoWrap" Padding="12" />
                </ScrollViewer>

                <!-- Structured view -->
                <Grid IsVisible="{Binding IsStructuredView}" RowDefinitions="*,Auto">

                    <!-- Entry list -->
                    <ListBox ItemsSource="{Binding FilteredEntries}"
                             SelectedItem="{Binding SelectedEntry}"
                              BorderThickness="1" BorderBrush="{DynamicResource BorderColor}"
                              Background="{DynamicResource CardBackground}">
                        <ListBox.ItemTemplate>
                            <DataTemplate x:DataType="models:LogEntry">
                                <Border Padding="8 4" Margin="2 1" CornerRadius="3"
                                        Background="{DynamicResource CardBackground}">
                                    <Grid ColumnDefinitions="55,Auto,*,Auto" ColumnSpacing="8">
                                        <Border Background="{Binding LevelBadge}" CornerRadius="3"
                                                Padding="4 1" VerticalAlignment="Center"
                                                HorizontalAlignment="Center">
                                            <TextBlock Text="{Binding LevelBadgeText}"
                                                       Foreground="{Binding LevelBadgeTextColor}"
                                                       FontSize="10" FontWeight="Bold" />
                                        </Border>

                                        <TextBlock Grid.Column="1" Text="{Binding FormattedTimestamp}"
                                                   FontSize="11" Opacity="0.7"
                                                   VerticalAlignment="Center" />

                                        <TextBlock Grid.Column="2" Text="{Binding ShortMessage}"
                                                   FontSize="12" Foreground="{DynamicResource ConsoleForeground}"
                                                   VerticalAlignment="Center"
                                                   TextTrimming="CharacterEllipsis" />

                                        <TextBlock Grid.Column="3"
                                                   FontSize="10" Opacity="0.4" VerticalAlignment="Center"
                                                   Text="▸" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <!-- Detail panel (when entry selected) -->
                    <Border Grid.Row="1" BorderBrush="{DynamicResource ConsoleBorder}" BorderThickness="0 1 0 0"
                            Background="{DynamicResource ConsoleBackground}" Padding="8" MaxHeight="250"
                            IsVisible="{Binding HasSelectedEntry}">
                        <Grid RowDefinitions="Auto,*" ColumnDefinitions="*,Auto">
                            <Border CornerRadius="3" Padding="4 2"
                                    Background="{Binding SelectedEntry.LevelBadge}"
                                    VerticalAlignment="Center" HorizontalAlignment="Left">
                                <TextBlock Text="{Binding SelectedEntry.LevelBadgeText}"
                                           Foreground="{Binding SelectedEntry.LevelBadgeTextColor}"
                                           FontSize="11" FontWeight="Bold" />
                            </Border>

                            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4">
                                <Button Command="{Binding CopyEntryCommand}" Height="24" Padding="6 0"
                                        Background="#3A3A3A" Foreground="#E0E0E0" FontSize="10"
                                        CornerRadius="3" BorderThickness="0" VerticalContentAlignment="Center"
                                        ToolTip.Tip="Copiar entrada">
                                    <TextBlock Text="📋 Copiar" FontSize="10" />
                                </Button>
                            </StackPanel>

                            <ScrollViewer Grid.Row="1" Grid.ColumnSpan="2" Margin="0 4 0 0">
                    <TextBox Text="{Binding DetailContent}" Classes="Console"
                             BorderThickness="0" Focusable="False"
                             TextWrapping="Wrap" Padding="4" />
                            </ScrollViewer>
                        </Grid>
                    </Border>

                    <!-- Placeholder (no entry selected) -->
                    <Border Grid.Row="1" BorderBrush="{DynamicResource BorderColor}" BorderThickness="0 1 0 0"
                            Background="{DynamicResource SurfaceBackground}" Padding="8"
                            IsVisible="{Binding ShowPlaceholder}">
                        <TextBlock Text="Selecione uma entrada para ver detalhes."
                                   FontSize="12" Opacity="0.4" VerticalAlignment="Center"
                                   HorizontalAlignment="Center" />
                    </Border>
                </Grid>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
