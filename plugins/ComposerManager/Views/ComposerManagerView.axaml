<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:LTools.ComposerManager.ViewModels"
             x:DataType="vm:ComposerManagerViewModel"
             x:Class="LTools.ComposerManager.Views.ComposerManagerView">

    <Grid RowDefinitions="Auto,Auto,*,Auto">
        <Border Padding="12 8" BorderBrush="#33000000" BorderThickness="0 0 0 1">
            <Grid ColumnDefinitions="Auto,Auto,*,Auto">
                <Button Command="{Binding SelectProjectCommand}" Padding="8 4" Margin="0 0 8 0">
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <TextBlock Text="📂" />
                        <TextBlock Text="{Binding ProjectName, TargetNullValue='Selecionar Projeto'}" />
                    </StackPanel>
                </Button>
                <TextBlock Grid.Column="1" Text="{Binding StatusMessage}" VerticalAlignment="Center" FontSize="12" Opacity="0.7" />
                <Button Grid.Column="3" Command="{Binding ClearOutputCommand}" Padding="8 4">
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <TextBlock Text="🗑" />
                        <TextBlock Text="Limpar" />
                    </StackPanel>
                </Button>
            </Grid>
        </Border>

        <WrapPanel Grid.Row="1" Margin="8 8 8 0">
            <Button Command="{Binding InstallCommand}" Padding="12 6" FontWeight="Bold" Margin="0 0 6 6"
                    Background="{DynamicResource SystemAccentColor}" Foreground="White">
                <StackPanel Orientation="Horizontal" Spacing="4">
                    <TextBlock Text="📥" />
                    <TextBlock Text="Install" />
                </StackPanel>
            </Button>
            <Button Command="{Binding UpdateCommand}" Padding="12 6" FontWeight="Bold" Margin="0 0 6 6">
                <StackPanel Orientation="Horizontal" Spacing="4">
                    <TextBlock Text="🔄" />
                    <TextBlock Text="Update" />
                </StackPanel>
            </Button>
            <Button Command="{Binding OutdatedCommand}" Padding="12 6" Margin="0 0 6 6">
                <StackPanel Orientation="Horizontal" Spacing="4">
                    <TextBlock Text="🔍" />
                    <TextBlock Text="Outdated" />
                </StackPanel>
            </Button>
            <Button Command="{Binding ShowCommand}" Padding="12 6" Margin="0 0 6 6">
                <StackPanel Orientation="Horizontal" Spacing="4">
                    <TextBlock Text="📋" />
                    <TextBlock Text="Show" />
                </StackPanel>
            </Button>
            <TextBox Text="{Binding PackageName}" PlaceholderText="pacote/exemplo" MinWidth="200" Margin="0 0 6 6" />
            <Button Command="{Binding RequireCommand}" Padding="12 6" Margin="0 0 6 6"
                    Background="{DynamicResource SystemAccentColor}" Foreground="White">
                <StackPanel Orientation="Horizontal" Spacing="4">
                    <TextBlock Text="➕" />
                    <TextBlock Text="Require" />
                </StackPanel>
            </Button>
            <Button Command="{Binding RemoveCommand}" Padding="12 6" Margin="0 0 6 6">
                <StackPanel Orientation="Horizontal" Spacing="4">
                    <TextBlock Text="➖" />
                    <TextBlock Text="Remove" />
                </StackPanel>
            </Button>
        </WrapPanel>

        <Grid Grid.Row="2" ColumnDefinitions="250,*" Margin="8">
            <Border BorderBrush="#33000000" BorderThickness="0 0 1 0" Padding="8">
                <StackPanel Spacing="4">
                    <TextBlock Text="Dependências" FontWeight="SemiBold" FontSize="14" Margin="0 0 0 8" />
                    <ListBox ItemsSource="{Binding Packages}" BorderThickness="0" Background="Transparent">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="6 4" Margin="0 0 0 2" CornerRadius="4" Background="#1A0078D4">
                                    <Grid ColumnDefinitions="*,Auto">
                                        <StackPanel>
                                            <TextBlock Text="{Binding Name}" FontSize="13" FontWeight="SemiBold" />
                                            <TextBlock Text="{Binding Version}" FontSize="11" Opacity="0.7" />
                                        </StackPanel>
                                        <Border Grid.Column="1" CornerRadius="3" Padding="4 2" Background="#33000000" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Type}" FontSize="10" Opacity="0.6" />
                                        </Border>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </StackPanel>
            </Border>

            <Border Grid.Column="1" Margin="8 0 0 0" CornerRadius="4" Background="#1E1E1E"
                    BorderBrush="#333333" BorderThickness="1">
                <ScrollViewer>
                    <TextBlock Text="{Binding OutputText}"
                               FontFamily="Consolas" FontSize="13"
                               Foreground="#D4D4D4"
                               TextWrapping="Wrap"
                               Padding="12" />
                </ScrollViewer>
            </Border>
        </Grid>

        <Border Grid.Row="3" Padding="12 6" BorderBrush="#33000000" BorderThickness="0 1 0 0">
            <TextBlock Text="{Binding StatusMessage}" FontSize="12" Opacity="0.6" VerticalAlignment="Center" />
        </Border>
    </Grid>

</UserControl>