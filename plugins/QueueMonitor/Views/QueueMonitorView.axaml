<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:LTools.QueueMonitor.ViewModels"
             xmlns:models="using:LTools.QueueMonitor.Models"
             xmlns:local="using:LTools.QueueMonitor.Views"
             x:DataType="vm:QueueMonitorViewModel"
             x:Class="LTools.QueueMonitor.Views.QueueMonitorView">

    <UserControl.Resources>
        <local:InverseBoolConverter x:Key="InverseBool" />
        <local:BoolToTabBgConverter x:Key="TabBg" />
        <local:BoolToStatusColorConverter x:Key="StatusColor" />
    </UserControl.Resources>

    <Grid RowDefinitions="Auto,*">

        <!-- ═══ STATUS BAR ═══ -->
        <Border Padding="12 8" BorderBrush="#33FFFFFF" BorderThickness="0 0 0 1">
            <Grid ColumnDefinitions="*,Auto,Auto,Auto">
                <TextBlock Text="{Binding StatusMessage}" VerticalAlignment="Center"
                           FontSize="12" Opacity="0.8" TextTrimming="CharacterEllipsis" />

                <Border Grid.Column="1" CornerRadius="3" Padding="6 2" Margin="0 0 8 0"
                        Background="#33CC3333" VerticalAlignment="Center"
                        IsVisible="{Binding HasFailedJobs}">
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <TextBlock Text="⚠" FontSize="12" />
                        <TextBlock Text="{Binding FailedJobsSummary}"
                                   FontSize="11" FontWeight="SemiBold" />
                    </StackPanel>
                </Border>

                <TextBlock Grid.Column="2" VerticalAlignment="Center" FontSize="11"
                           Opacity="0.4" Margin="0 0 12 0"
                           Text="{Binding LastCheckLabel}" />

                <ToggleButton Grid.Column="3" IsChecked="{Binding IsAutoRefreshEnabled}"
                              Height="26" Padding="8 0" FontSize="11"
                              Background="#3A3A3A" Foreground="#E0E0E0"
                              CornerRadius="3" BorderThickness="0"
                              VerticalContentAlignment="Center"
                              ToolTip.Tip="Auto-refresh a cada 30s">
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <TextBlock Text="⏱" FontSize="11" />
                        <TextBlock Text="Auto" FontSize="11" />
                    </StackPanel>
                </ToggleButton>
            </Grid>
        </Border>

        <!-- ═══ SIMPLE CONTENT (adding sections gradually) ═══ -->
        <ScrollViewer Grid.Row="1">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="8">
                <TextBlock Text="QUEUE MONITOR" FontSize="20" FontWeight="Bold"
                           Foreground="#88DD88" HorizontalAlignment="Center" />
                <TextBlock Text="{Binding StatusMessage}" FontSize="13"
                           HorizontalAlignment="Center" />
            </StackPanel>
        </ScrollViewer>

    </Grid>
</UserControl>
