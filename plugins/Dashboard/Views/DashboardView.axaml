<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:LTools.Dashboard.ViewModels"
             x:DataType="vm:DashboardViewModel"
             x:Class="LTools.Dashboard.Views.DashboardView">

    <ScrollViewer Padding="20">
        <StackPanel Spacing="16">
            <TextBlock Text="Dashboard"
                       FontSize="{DynamicResource FontSizePageTitle}"
                       FontWeight="Bold" />

            <TextBlock Text="{Binding StatusMessage}"
                       FontSize="{DynamicResource FontSizeBody}"
                       Opacity="0.7" />

            <!-- Project Info -->
            <Border Background="{DynamicResource AccentBg}"
                    CornerRadius="8"
                    Padding="20"
                    IsVisible="{Binding HasProject}">
                <StackPanel Spacing="12">
                    <TextBlock Text="Projeto Atual"
                               FontSize="{DynamicResource FontSizeSectionTitle}"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource TextAccent}" />

                    <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto">
                        <TextBlock Text="Nome:" FontWeight="Bold" Margin="0,0,16,4" />
                        <TextBlock Grid.Column="1" Text="{Binding ProjectName}" />

                        <TextBlock Grid.Row="1" Text="Caminho:" FontWeight="Bold" Margin="0,0,16,4" />
                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding ProjectPath}" FontSize="12" Opacity="0.7" />

                        <TextBlock Grid.Row="2" Text="Tamanho:" FontWeight="Bold" Margin="0,0,16,4" />
                        <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding ProjectSize}" />

                        <TextBlock Grid.Row="3" Text="Ambiente:" FontWeight="Bold" Margin="0,0,16,4" />
                        <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding Env}" />

                        <TextBlock Grid.Row="4" Text="Debug:" FontWeight="Bold" Margin="0,0,16,4" />
                        <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding DebugMode}" />

                        <TextBlock Grid.Row="5" Text="URL:" FontWeight="Bold" Margin="0,0,16,4" />
                        <TextBlock Grid.Row="5" Grid.Column="1" Text="{Binding Url}" />

                        <TextBlock Grid.Row="6" Text="Laravel:" FontWeight="Bold" Margin="0,0,16,4" />
                        <TextBlock Grid.Row="6" Grid.Column="1" Text="{Binding LaravelVersion}" />

                        <TextBlock Grid.Row="7" Text="PHP:" FontWeight="Bold" Margin="0,0,16,4" />
                        <TextBlock Grid.Row="7" Grid.Column="1" Text="{Binding PhpVersion}" />

                        <TextBlock Grid.Row="8" Text="Cache Config:" FontWeight="Bold" Margin="0,0,16,4" />
                        <TextBlock Grid.Row="8" Grid.Column="1" Text="{Binding CacheConfig}" />

                        <TextBlock Grid.Row="9" Text="Cache Rotas:" FontWeight="Bold" Margin="0,0,16,4" />
                        <TextBlock Grid.Row="9" Grid.Column="1" Text="{Binding CacheRoutes}" />

                        <TextBlock Grid.Row="10" Text="Banco:" FontWeight="Bold" Margin="0,0,16,4" />
                        <TextBlock Grid.Row="10" Grid.Column="1" Text="{Binding DatabaseDriver}" />

                        <TextBlock Grid.Row="11" Text="Logs:" FontWeight="Bold" Margin="0,0,16,4" />
                        <TextBlock Grid.Row="11" Grid.Column="1" Text="{Binding LogsDriver}" />
                    </Grid>
                </StackPanel>
            </Border>

            <!-- File Counts -->
            <Border Background="{DynamicResource SurfaceBackground}"
                    CornerRadius="8"
                    Padding="20"
                    IsVisible="{Binding HasProject}">
                <StackPanel Spacing="12">
                    <TextBlock Text="Artefatos do Projeto"
                               FontSize="{DynamicResource FontSizeSectionTitle}"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource TextAccent}" />

                    <UniformGrid Columns="3" Margin="0 0 0 0">
                        <Border CornerRadius="6" Background="{DynamicResource CardBackground}" Padding="12 10" Margin="0 0 6 6">
                            <StackPanel Spacing="2">
                                <TextBlock Text="{Binding MigrationsCount}"                                FontSize="{DynamicResource FontSizeCardNumber}" FontWeight="Bold" Foreground="#E67E22" />
                                <TextBlock Text="migrations" FontSize="{DynamicResource FontSizeSmall}" Opacity="0.7" />
                            </StackPanel>
                        </Border>
                        <Border CornerRadius="6" Background="{DynamicResource CardBackground}" Padding="12 10" Margin="0 0 6 6">
                            <StackPanel Spacing="2">
                                <TextBlock Text="{Binding ModelsCount}"                                FontSize="{DynamicResource FontSizeCardNumber}" FontWeight="Bold" Foreground="#E67E22" />
                                <TextBlock Text="models" FontSize="12" Opacity="0.7" />
                            </StackPanel>
                        </Border>
                        <Border CornerRadius="6" Background="{DynamicResource CardBackground}" Padding="12 10" Margin="0 0 0 6">
                            <StackPanel Spacing="2">
                                <TextBlock Text="{Binding ControllersCount}"                                FontSize="{DynamicResource FontSizeCardNumber}" FontWeight="Bold" Foreground="#E67E22" />
                                <TextBlock Text="controllers" FontSize="12" Opacity="0.7" />
                            </StackPanel>
                        </Border>
                        <Border CornerRadius="6" Background="{DynamicResource CardBackground}" Padding="12 10" Margin="0 0 6 6">
                            <StackPanel Spacing="2">
                                <TextBlock Text="{Binding JobsCount}"                                FontSize="{DynamicResource FontSizeCardNumber}" FontWeight="Bold" Foreground="#E67E22" />
                                <TextBlock Text="jobs" FontSize="12" Opacity="0.7" />
                            </StackPanel>
                        </Border>
                        <Border CornerRadius="6" Background="{DynamicResource CardBackground}" Padding="12 10" Margin="0 0 6 6">
                            <StackPanel Spacing="2">
                                <TextBlock Text="{Binding ServicesCount}"                                FontSize="{DynamicResource FontSizeCardNumber}" FontWeight="Bold" Foreground="#E67E22" />
                                <TextBlock Text="services" FontSize="12" Opacity="0.7" />
                            </StackPanel>
                        </Border>
                        <Border CornerRadius="6" Background="{DynamicResource CardBackground}" Padding="12 10" Margin="0 0 0 6">
                            <StackPanel Spacing="2">
                                <TextBlock Text="{Binding MiddlewareCount}"                                FontSize="{DynamicResource FontSizeCardNumber}" FontWeight="Bold" Foreground="#E67E22" />
                                <TextBlock Text="middleware" FontSize="12" Opacity="0.7" />
                            </StackPanel>
                        </Border>
                        <Border CornerRadius="6" Background="{DynamicResource CardBackground}" Padding="12 10" Margin="0 0 6 6">
                            <StackPanel Spacing="2">
                                <TextBlock Text="{Binding EventsCount}"                                FontSize="{DynamicResource FontSizeCardNumber}" FontWeight="Bold" Foreground="#E67E22" />
                                <TextBlock Text="events" FontSize="12" Opacity="0.7" />
                            </StackPanel>
                        </Border>
                        <Border CornerRadius="6" Background="{DynamicResource CardBackground}" Padding="12 10" Margin="0 0 6 6">
                            <StackPanel Spacing="2">
                                <TextBlock Text="{Binding ListenersCount}"                                FontSize="{DynamicResource FontSizeCardNumber}" FontWeight="Bold" Foreground="#E67E22" />
                                <TextBlock Text="listeners" FontSize="12" Opacity="0.7" />
                            </StackPanel>
                        </Border>
                        <Border CornerRadius="6" Background="{DynamicResource CardBackground}" Padding="12 10" Margin="0 0 0 6">
                            <StackPanel Spacing="2">
                                <TextBlock Text="{Binding NotificationsCount}"                                FontSize="{DynamicResource FontSizeCardNumber}" FontWeight="Bold" Foreground="#E67E22" />
                                <TextBlock Text="notifications" FontSize="12" Opacity="0.7" />
                            </StackPanel>
                        </Border>
                        <Border CornerRadius="6" Background="{DynamicResource CardBackground}" Padding="12 10" Margin="0 0 6 6">
                            <StackPanel Spacing="2">
                                <TextBlock Text="{Binding MailCount}"                                FontSize="{DynamicResource FontSizeCardNumber}" FontWeight="Bold" Foreground="#E67E22" />
                                <TextBlock Text="mail" FontSize="12" Opacity="0.7" />
                            </StackPanel>
                        </Border>
                        <Border CornerRadius="6" Background="{DynamicResource CardBackground}" Padding="12 10" Margin="0 0 6 6">
                            <StackPanel Spacing="2">
                                <TextBlock Text="{Binding ObserversCount}"                                FontSize="{DynamicResource FontSizeCardNumber}" FontWeight="Bold" Foreground="#E67E22" />
                                <TextBlock Text="observers" FontSize="12" Opacity="0.7" />
                            </StackPanel>
                        </Border>
                        <Border CornerRadius="6" Background="{DynamicResource CardBackground}" Padding="12 10" Margin="0 0 0 6">
                            <StackPanel Spacing="2">
                                <TextBlock Text="{Binding PoliciesCount}"                                FontSize="{DynamicResource FontSizeCardNumber}" FontWeight="Bold" Foreground="#E67E22" />
                                <TextBlock Text="policies" FontSize="12" Opacity="0.7" />
                            </StackPanel>
                        </Border>
                        <Border CornerRadius="6" Background="{DynamicResource CardBackground}" Padding="12 10" Margin="0 0 6 6">
                            <StackPanel Spacing="2">
                                <TextBlock Text="{Binding ProvidersCount}"                                FontSize="{DynamicResource FontSizeCardNumber}" FontWeight="Bold" Foreground="#E67E22" />
                                <TextBlock Text="providers" FontSize="12" Opacity="0.7" />
                            </StackPanel>
                        </Border>
                        <Border CornerRadius="6" Background="{DynamicResource CardBackground}" Padding="12 10" Margin="0 0 6 6">
                            <StackPanel Spacing="2">
                                <TextBlock Text="{Binding CommandsCount}"                                FontSize="{DynamicResource FontSizeCardNumber}" FontWeight="Bold" Foreground="#E67E22" />
                                <TextBlock Text="commands" FontSize="12" Opacity="0.7" />
                            </StackPanel>
                        </Border>
                        <Border CornerRadius="6" Background="{DynamicResource CardBackground}" Padding="12 10" Margin="0 0 0 6">
                            <StackPanel Spacing="2">
                                <TextBlock Text="{Binding RoutesCount}"                                FontSize="{DynamicResource FontSizeCardNumber}" FontWeight="Bold" Foreground="#E67E22" />
                                <TextBlock Text="routes (arquivos)" FontSize="12" Opacity="0.7" />
                            </StackPanel>
                        </Border>
                        <Border CornerRadius="6" Background="{DynamicResource CardBackground}" Padding="12 10" Margin="0 0 6 6">
                            <StackPanel Spacing="2">
                                <TextBlock Text="{Binding FactoriesCount}"                                FontSize="{DynamicResource FontSizeCardNumber}" FontWeight="Bold" Foreground="#E67E22" />
                                <TextBlock Text="factories" FontSize="12" Opacity="0.7" />
                            </StackPanel>
                        </Border>
                        <Border CornerRadius="6" Background="{DynamicResource CardBackground}" Padding="12 10" Margin="0 0 6 6">
                            <StackPanel Spacing="2">
                                <TextBlock Text="{Binding SeedersCount}"                                FontSize="{DynamicResource FontSizeCardNumber}" FontWeight="Bold" Foreground="#E67E22" />
                                <TextBlock Text="seeders" FontSize="12" Opacity="0.7" />
                            </StackPanel>
                        </Border>
                        <Border CornerRadius="6" Background="{DynamicResource CardBackground}" Padding="12 10" Margin="0 0 0 6">
                            <StackPanel Spacing="2">
                                <TextBlock Text="{Binding TestsCount}"                                FontSize="{DynamicResource FontSizeCardNumber}" FontWeight="Bold" Foreground="#E67E22" />
                                <TextBlock Text="tests" FontSize="12" Opacity="0.7" />
                            </StackPanel>
                        </Border>
                        <Border CornerRadius="6" Background="{DynamicResource CardBackground}" Padding="12 10" Margin="0 0 6 0">
                            <StackPanel Spacing="2">
                                <TextBlock Text="{Binding PackagesCount}"                                FontSize="{DynamicResource FontSizeCardNumber}" FontWeight="Bold" Foreground="#E67E22" />
                                <TextBlock Text="pacotes" FontSize="12" Opacity="0.7" />
                            </StackPanel>
                        </Border>
                        <Border CornerRadius="6" Background="{DynamicResource CardBackground}" Padding="12 10" Margin="0 0 6 0">
                            <StackPanel Spacing="2">
                                <TextBlock Text="{Binding DevPackagesCount}"                                FontSize="{DynamicResource FontSizeCardNumber}" FontWeight="Bold" Foreground="#E67E22" />
                                <TextBlock Text="pacotes (dev)" FontSize="12" Opacity="0.7" />
                            </StackPanel>
                        </Border>
                    </UniformGrid>
                </StackPanel>
            </Border>

            <!-- Global Tools -->
            <Border Background="{DynamicResource AccentBg}"
                    CornerRadius="8"
                    Padding="20">
                <StackPanel Spacing="12">
                    <TextBlock Text="Ferramentas Detectadas"
                               FontSize="{DynamicResource FontSizeSectionTitle}"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource TextAccent}" />

                    <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto">
                        <TextBlock Text="PHP:" FontWeight="Bold" Margin="0,0,16,4" />
                        <TextBlock Grid.Column="1" Text="{Binding PhpVersion}" />

                        <TextBlock Grid.Row="1" Text="Laravel CLI:" FontWeight="Bold" Margin="0,0,16,4" />
                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding LaravelCliVersion}" />

                        <TextBlock Grid.Row="2" Text="Composer:" FontWeight="Bold" Margin="0,0,16,4" />
                        <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding ComposerVersion}" />

                        <TextBlock Grid.Row="3" Text="Git:" FontWeight="Bold" Margin="0,0,16,4" />
                        <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding GitVersion}" />

                        <TextBlock Grid.Row="4" Text="Node:" FontWeight="Bold" Margin="0,0,16,4" />
                        <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding NodeVersion}" />

                        <TextBlock Grid.Row="5" Text="Docker:" FontWeight="Bold" Margin="0,0,16,4" />
                        <TextBlock Grid.Row="5" Grid.Column="1" Text="{Binding DockerVersion}" />
                    </Grid>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>

</UserControl>
