<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:LTools.SqlDebugger.ViewModels"
             x:DataType="vm:SqlDebuggerViewModel"
             x:Class="LTools.SqlDebugger.Views.SqlDebuggerView">

    <Grid RowDefinitions="Auto,Auto,*">
        <Border Padding="12 8" BorderBrush="#33000000" BorderThickness="0 0 0 1">
            <Grid ColumnDefinitions="*,Auto">
                <TextBlock Text="{Binding StatusMessage}" VerticalAlignment="Center" FontSize="12" Opacity="0.7" />
                <Button Grid.Column="1" Command="{Binding RefreshCommand}" Padding="8 4">
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <TextBlock Text="🔄" />
                        <TextBlock Text="Atualizar" />
                    </StackPanel>
                </Button>
            </Grid>
        </Border>

        <Border Grid.Row="1" Margin="8 8 8 0" Padding="12" CornerRadius="4" Background="#1A0078D4">
            <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto">
                <TextBlock Text="Conexão:" FontWeight="Bold" Margin="0 0 16 4" />
                <TextBlock Grid.Column="1" Text="{Binding DbConnection, TargetNullValue='—'}" />

                <TextBlock Grid.Row="1" Text="Host:" FontWeight="Bold" Margin="0 0 16 4" />
                <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding DbHost, TargetNullValue='—'}" />

                <TextBlock Grid.Row="2" Text="Porta:" FontWeight="Bold" Margin="0 0 16 4" />
                <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding DbPort, TargetNullValue='—'}" />

                <TextBlock Grid.Row="3" Text="Database:" FontWeight="Bold" Margin="0 0 16 4" />
                <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding DbName, TargetNullValue='—'}" />

                <TextBlock Grid.Row="4" Text="Usuário:" FontWeight="Bold" Margin="0 0 16 4" />
                <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding DbUser, TargetNullValue='—'}" />
            </Grid>
        </Border>

        <ListBox Grid.Row="2" ItemsSource="{Binding Tables}" Margin="8"
                 BorderThickness="0" Background="Transparent">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Border Padding="10 6" Margin="0 0 0 3" CornerRadius="4"
                            BorderBrush="#22000000" BorderThickness="0 0 0 1">
                        <Grid ColumnDefinitions="*,Auto,Auto,Auto">
                            <TextBlock Text="{Binding Name}" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center" />
                            <TextBlock Grid.Column="1" Text="{Binding Rows, StringFormat='{}{0} linhas'}"
                                       FontSize="11" Opacity="0.6" VerticalAlignment="Center" Margin="8 0" />
                            <TextBlock Grid.Column="2" Text="{Binding Size}" FontSize="11" Opacity="0.6"
                                       VerticalAlignment="Center" Margin="8 0" />
                            <Border Grid.Column="3" CornerRadius="3" Padding="4 2" Background="#33000000" VerticalAlignment="Center">
                                <TextBlock Text="{Binding Engine}" FontSize="10" Opacity="0.6" />
                            </Border>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </Grid>

</UserControl>